{%- comment -%}
  Inner content of a mega menu: promo column (heading, subheading, button) + up to 3 cards.
  Rendered inside the desktop dropdown and the mobile menu overlay.

  Accepts:
  - block {object} - a `mega_menu` block from sections/header.liquid
{%- endcomment -%}

<div class="yw-mega__promo">
  {%- if block.settings.heading != blank -%}
    <p class="yw-mega__heading">{{ block.settings.heading }}</p>
  {%- endif -%}
  {%- if block.settings.subheading != blank -%}
    <p class="yw-mega__subheading">{{ block.settings.subheading }}</p>
  {%- endif -%}
  {%- if block.settings.button_label != blank -%}
    <a class="yw-mega__button" href="{{ block.settings.button_link | default: routes.all_products_collection_url }}">
      {{- block.settings.button_label -}}
    </a>
  {%- endif -%}
</div>

<div class="yw-mega__cards">
  {%- for i in (1..3) -%}
    {%- assign image_key = 'card_' | append: i | append: '_image' -%}
    {%- assign title_key = 'card_' | append: i | append: '_title' -%}
    {%- assign caption_key = 'card_' | append: i | append: '_caption' -%}
    {%- assign link_key = 'card_' | append: i | append: '_link' -%}
    {%- assign card_image = block.settings[image_key] -%}
    {%- assign card_title = block.settings[title_key] -%}
    {%- assign card_caption = block.settings[caption_key] -%}
    {%- assign card_link = block.settings[link_key] -%}

    {%- if card_title != blank or card_image != blank -%}
      <a class="yw-mega-card" href="{{ card_link | default: routes.all_products_collection_url }}">
        <span class="yw-mega-card__media">
          {%- if card_image != blank -%}
            {{
              card_image
              | image_url: width: 400
              | image_tag: alt: card_title, class: 'yw-mega-card__img', widths: '200, 300, 400', loading: 'lazy'
            }}
          {%- endif -%}
        </span>
        <span class="yw-mega-card__text">
          {%- if card_title != blank -%}
            <span class="yw-mega-card__title">{{ card_title }}</span>
          {%- endif -%}
          {%- if card_caption != blank -%}
            <span class="yw-mega-card__caption">{{ card_caption }}</span>
          {%- endif -%}
        </span>
      </a>
    {%- endif -%}
  {%- endfor -%}
</div>
