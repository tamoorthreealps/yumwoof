{{ 'hero-banner.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} .hero-banner {
    --hb-bg: {{ section.settings.background_color }};
    --hb-text: {{ section.settings.text_color }};
    --hb-btn-bg: {{ section.settings.button_bg }};
    --hb-btn-text: {{ section.settings.button_text_color }};
    --hb-btn-border: {{ section.settings.button_border_color }};
    --hb-min-height: {{ section.settings.min_height }}px;
    --hb-min-height-mobile: {{ section.settings.min_height_mobile }}px;
  }
{%- endstyle -%}

<section
  class="hero-banner hero-banner--{{ section.settings.content_position }} hero-banner--{{ section.settings.content_alignment }}{% if section.settings.show_texture %} hero-banner--texture{% endif %}{% if section.settings.uppercase_heading %} hero-banner--uppercase{% endif %}"
>
  {%- if section.settings.background_image != blank -%}
    {{
      section.settings.background_image
      | image_url: width: 3000
      | image_tag:
        class: 'hero-banner__image',
        widths: '750, 1100, 1500, 2000, 3000',
        sizes: '100vw',
        alt: section.settings.background_image.alt | default: section.settings.heading,
        loading: 'eager',
        fetchpriority: 'high'
    }}
  {%- endif -%}

  <div class="hero-banner__inner">
    <div class="hero-banner__content">
      {%- if section.settings.heading != blank -%}
        <h1 class="hero-banner__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="hero-banner__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.button_label != blank or section.settings.offer_text != blank -%}
        <div class="hero-banner__cta-wrap">
          {%- if section.settings.button_label != blank -%}
            <a class="hero-banner__cta" href="{{ section.settings.button_link | default: '#' }}">
              {{- section.settings.button_label -}}
            </a>
          {%- endif -%}
          {%- if section.settings.offer_text != blank -%}
            <p class="hero-banner__offer">{{ section.settings.offer_text }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero banner",
  "tag": "section",
  "class": "section-hero-banner",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How dogs were meant to eat."
    },
    {
      "type": "checkbox",
      "id": "uppercase_heading",
      "label": "Uppercase heading",
      "default": true
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Next-level nutrition. Your dog deserves it."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Take the quiz"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "offer_text",
      "label": "Offer text",
      "default": "Get 30% Off and Free Shipping."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content vertical position",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "middle", "label": "Middle" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "bottom"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 400,
      "max": 900,
      "step": 20,
      "unit": "px",
      "label": "Minimum height (desktop)",
      "default": 620
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "min": 320,
      "max": 720,
      "step": 20,
      "unit": "px",
      "label": "Minimum height (mobile)",
      "default": 480
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "info": "Optional. Sits behind the text on the dark background."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#1A1A1A"
    },
    {
      "type": "checkbox",
      "id": "show_texture",
      "label": "Show grain texture",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFF9EF"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#FFC069"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Button border",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Hero banner"
    }
  ]
}
{% endschema %}
