{{ 'css--heritage-recipes.css' | asset_url | stylesheet_tag }}

{%- style -%}
#shopify-section-{{ section.id }} .heritage {
  --hr-bg: {{ section.settings.background_color }};
  --hr-text: {{ section.settings.text_color }};
  --hr-card-bg: {{ section.settings.card_background }};
  --hr-card-border: {{ section.settings.card_border }};

  {% if section.settings.background_image != blank %}
    background-image: url('{{ section.settings.background_image | image_url: width: 2500 }}');
    background-size: 100% 100%;
    background-position: center;
    background-repeat: no-repeat;
  {% else %}
    background-color: var(--hr-bg);
  {% endif %}
}

@media (max-width: 989px) {
  #shopify-section-{{ section.id }} .heritage {
    {% if section.settings.background_image_mobile != blank %}
      background-image: url('{{ section.settings.background_image_mobile | image_url: width: 1200 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      background-color: transparent;
    {% elsif section.settings.background_image != blank %}
      background-image: url('{{ section.settings.background_image | image_url: width: 1200 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      background-color: transparent;
    {% else %}
      background-image: none;
      background-color: var(--hr-bg);
    {% endif %}
  }
}
{%- endstyle -%}

{%- capture x_icon -%}
  <svg class="heritage-chip__x" viewBox="0 0 10 10" fill="none" aria-hidden="true" focusable="false">
    <path d="M1 1L9 9M9 1L1 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
  </svg>
{%- endcapture -%}

<section class="heritage{% if section.settings.uppercase_heading %} heritage--uppercase{% endif %}" data-marquee>
  <div class="heritage__container">
    {%- comment -%} -------- Left: intro + bowl -------- {%- endcomment -%}
    <div class="heritage__intro">
      {%- if section.settings.heading != blank -%}
        <h2 class="heritage__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="heritage__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a class="heritage__button" href="{{ section.settings.button_link | default: '#' }}">
          {{- section.settings.button_label -}}
        </a>
      {%- endif -%}

      {%- if section.settings.bowl_image != blank -%}
        {%- assign bowl_alt = section.settings.bowl_image.alt | default: '' -%}
        <div class="heritage__bowl">
          {{
            section.settings.bowl_image
            | image_url: width: 900
            | image_tag: widths: '300, 500, 700, 900', alt: bowl_alt, loading: 'lazy'
          }}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} -------- Right: ingredient card -------- {%- endcomment -%}
    <div class="heritage__card-wrap">
      {%- if section.settings.kibble_image_1 != blank -%}
        <span class="heritage__kibble heritage__kibble--1">
          {{ section.settings.kibble_image_1 | image_url: width: 200 | image_tag: alt: '', loading: 'lazy' }}
        </span>
      {%- endif -%}
      {%- if section.settings.kibble_image_2 != blank -%}
        <span class="heritage__kibble heritage__kibble--2">
          {{ section.settings.kibble_image_2 | image_url: width: 200 | image_tag: alt: '', loading: 'lazy' }}
        </span>
      {%- endif -%}

      <div class="heritage__card">
        <ul class="heritage__ingredients">
          {%- for i in (1..4) -%}
            {%- assign title_key = 'ingredient_' | append: i | append: '_title' -%}
            {%- assign text_key = 'ingredient_' | append: i | append: '_text' -%}
            {%- assign image_key = 'ingredient_' | append: i | append: '_image' -%}
            {%- assign title = section.settings[title_key] -%}
            {%- assign text = section.settings[text_key] -%}
            {%- assign image = section.settings[image_key] -%}
            {%- if title != blank or image != blank -%}
              <li class="heritage__ingredient">
                <span class="heritage__ingredient-media">
                  {%- if image != blank -%}
                    {{ image | image_url: width: 160 | image_tag: class: 'heritage__ingredient-img', alt: title, widths: '80, 120, 160', loading: 'lazy' }}
                  {%- endif -%}
                </span>
                <span class="heritage__ingredient-text">
                  {%- if title != blank -%}<span class="heritage__ingredient-title">{{ title }}</span>{%- endif -%}
                  {%- if text != blank -%}<span class="heritage__ingredient-desc">{{ text }}</span>{%- endif -%}
                </span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
    </div>
  </div>

  {%- comment -%} -------- No-No list -------- {%- endcomment -%}
  {%- assign nono_items = section.settings.nono_items | split: ',' -%}
  {%- if section.settings.nono_heading != blank or nono_items.size > 0 -%}
    <div class="heritage__nono">
      <span class="heritage__divider" aria-hidden="true"></span>
      {%- if section.settings.nono_heading != blank -%}
        <h3 class="heritage__nono-heading">{{ section.settings.nono_heading }}</h3>
      {%- endif -%}
      {%- if section.settings.nono_subheading != blank -%}
        <p class="heritage__nono-subheading">{{ section.settings.nono_subheading }}</p>
      {%- endif -%}
    </div>

    {%- if nono_items.size > 0 -%}
      {%- comment -%} Split items into two rows (alternating) for the two marquee lines. {%- endcomment -%}
      <div class="heritage-marquee">
        {%- for row in (1..2) -%}
          <div class="heritage-marquee__row{% if row == 2 %} heritage-marquee__row--reverse{% endif %}" data-speed="{{ section.settings.marquee_speed }}">
            <div class="heritage-marquee__track">
              {%- for item in nono_items -%}
                {%- assign label = item | strip -%}
                {%- if label != blank -%}
                  {%- assign remainder = forloop.index0 | modulo: 2 -%}
                  {%- comment -%} Row 1 = even items, row 2 = odd items. {%- endcomment -%}
                  {%- assign target_row = remainder | plus: 1 -%}
                  {%- if target_row == row -%}
                    <span class="heritage-chip">{{ x_icon }}<span class="heritage-chip__label">{{ label }}</span></span>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- endif -%}
</section>

<script>
  (function () {
    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function initMarquee(section) {
      section.querySelectorAll('.heritage-marquee__row').forEach(function (row) {
        var track = row.querySelector('.heritage-marquee__track');
        if (!track || row.dataset.marqueeReady) return;

        var speed = parseFloat(row.dataset.speed) || 40; // pixels per second
        var width = track.getBoundingClientRect().width;
        if (width === 0) return;

        // Duplicate the chips so the -50% loop is seamless.
        var clone = track.cloneNode(true);
        clone.setAttribute('aria-hidden', 'true');
        row.appendChild(clone);
        row.style.setProperty('--marquee-duration', width / speed + 's');
        row.dataset.marqueeReady = 'true';
      });
    }

    function init(root) {
      root.querySelectorAll('.heritage[data-marquee]').forEach(function (section) {
        if (reduceMotion) return; // leave chips static
        initMarquee(section);
      });
    }

    if (document.readyState !== 'loading') {
      init(document);
    } else {
      document.addEventListener('DOMContentLoaded', function () {
        init(document);
      });
    }

    // Re-init inside the theme editor.
    document.addEventListener('shopify:section:load', function (event) {
      init(event.target);
    });
  })();
</script>

