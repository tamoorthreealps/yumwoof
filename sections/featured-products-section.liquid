{{ 'css--featured-products-section.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} .fp {
    --fp-bg: {{ section.settings.background_color }};
    --fp-text: {{ section.settings.text_color }};
    --fp-card-bg: {{ section.settings.card_background }};
    --fp-card-border: {{ section.settings.card_border }};
    --fp-label: {{ section.settings.label_color }};
  }
{%- endstyle -%}

{%- comment -%} Metafield keys come from settings as "namespace.key". {%- endcomment -%}
{%- assign labels_parts = section.settings.metafield_labels | split: '.' -%}
{%- assign desc_parts = section.settings.metafield_description | split: '.' -%}
{%- assign recipes_parts = section.settings.metafield_recipes_link | split: '.' -%}
{%- assign products = section.settings.products -%}

<section class="fp{% if section.settings.uppercase_heading %} fp--uppercase{% endif %}">
  <div class="fp__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="fp__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="fp__viewport" data-fp-viewport>
      <ul class="fp__track" data-fp-track role="list">
        {%- if products.size > 0 -%}
          {%- for product in products -%}
            {%- assign labels_mf = product.metafields[labels_parts[0]][labels_parts[1]] -%}
            {%- assign desc_mf = product.metafields[desc_parts[0]][desc_parts[1]] -%}
            {%- assign recipes_mf = product.metafields[recipes_parts[0]][recipes_parts[1]] -%}
            {%- comment -%} A "list" metafield already returns an array; a plain text one is comma separated. {%- endcomment -%}
            {%- if labels_mf.type contains 'list' -%}
              {%- assign labels_list = labels_mf.value -%}
            {%- else -%}
              {%- assign labels_list = labels_mf.value | split: ',' -%}
            {%- endif -%}
            {%- assign recipes_url = recipes_mf.value | default: product.url -%}

            <li class="fp__card" data-fp-slide>
              <h3 class="fp__title">{{ product.title }}</h3>

              {%- if labels_list.size > 0 -%}
                <ul class="fp__labels" role="list">
                  {%- for label in labels_list -%}
                    {%- assign label_text = label | strip -%}
                    {%- if label_text != blank -%}
                      <li class="fp__label">{{ label_text }}</li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              {%- endif -%}

              <a class="fp__media" href="{{ product.url }}" tabindex="-1" aria-hidden="true">
                {%- if product.featured_image -%}
                  {%- assign fp_alt = product.featured_image.alt | default: product.title -%}
                  {{
                    product.featured_image
                    | image_url: width: 600
                    | image_tag: class: 'fp__img', widths: '200, 300, 460, 600', alt: fp_alt, loading: 'lazy'
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'fp__img fp__img--placeholder' }}
                {%- endif -%}
              </a>

              {%- if desc_mf.value != blank -%}
                <p class="fp__desc">{{ desc_mf.value }}</p>
              {%- endif -%}

              {%- if section.settings.recipes_label != blank -%}
                <a class="fp__recipes" href="{{ recipes_url }}">{{ section.settings.recipes_label }}</a>
              {%- endif -%}

              <a class="fp__shop" href="{{ product.url }}">
                <span class="fp__shop-label">{{ section.settings.shop_label }}</span>
              </a>
            </li>
          {%- endfor -%}
        {%- else -%}
          {%- comment -%} Editor placeholders when no products are selected. {%- endcomment -%}
          {%- for i in (1..3) -%}
            <li class="fp__card" data-fp-slide>
              <h3 class="fp__title">{{ 'onboarding.product_title' | t }}</h3>
              <ul class="fp__labels" role="list">
                <li class="fp__label">Grain-Free</li>
                <li class="fp__label">Organ-Rich</li>
              </ul>
              <span class="fp__media">{{ 'product-1' | placeholder_svg_tag: 'fp__img fp__img--placeholder' }}</span>
              <p class="fp__desc">{{ 'onboarding.product_description' | t | truncatewords: 8 }}</p>
              <span class="fp__recipes">{{ section.settings.recipes_label }}</span>
              <span class="fp__shop"><span class="fp__shop-label">{{ section.settings.shop_label }}</span></span>
            </li>
          {%- endfor -%}
        {%- endif -%}
      </ul>
    </div>

    {%- if products.size > 1 -%}
      <div class="fp__nav" data-fp-nav>
        <button type="button" class="fp__arrow" data-fp-prev aria-label="{{ 'general.slider.previous_slide' | t | default: 'Previous' }}">
          <svg viewBox="0 0 12 12" fill="none" aria-hidden="true" focusable="false"><path d="M7.5 1.5 3 6l4.5 4.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="fp__dots" data-fp-dots></div>
        <button type="button" class="fp__arrow" data-fp-next aria-label="{{ 'general.slider.next_slide' | t | default: 'Next' }}">
          <svg viewBox="0 0 12 12" fill="none" aria-hidden="true" focusable="false"><path d="M4.5 1.5 9 6l-4.5 4.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  (function () {
    function initCarousel(section) {
      var viewport = section.querySelector('[data-fp-viewport]');
      var track = section.querySelector('[data-fp-track]');
      if (!viewport || !track || track.dataset.fpReady) return;

      var slides = Array.prototype.slice.call(track.querySelectorAll('[data-fp-slide]'));
      if (slides.length === 0) return;

      var prev = section.querySelector('[data-fp-prev]');
      var next = section.querySelector('[data-fp-next]');
      var dotsWrap = section.querySelector('[data-fp-dots]');
      var dots = [];

      if (dotsWrap) {
        dotsWrap.innerHTML = '';
        slides.forEach(function (_, i) {
          var dot = document.createElement('button');
          dot.type = 'button';
          dot.className = 'fp__dot';
          dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
          dot.addEventListener('click', function () { scrollToSlide(i); });
          dotsWrap.appendChild(dot);
          dots.push(dot);
        });
      }

      function scrollToSlide(i) {
        var slide = slides[i];
        if (!slide) return;
        var left = slide.offsetLeft - (viewport.clientWidth - slide.offsetWidth) / 2;
        viewport.scrollTo({ left: left, behavior: 'smooth' });
      }

      function currentIndex() {
        var center = viewport.scrollLeft + viewport.clientWidth / 2;
        var best = 0;
        var bestDist = Infinity;
        slides.forEach(function (slide, i) {
          var slideCenter = slide.offsetLeft + slide.offsetWidth / 2;
          var dist = Math.abs(slideCenter - center);
          if (dist < bestDist) { bestDist = dist; best = i; }
        });
        return best;
      }

      function update() {
        var idx = currentIndex();
        dots.forEach(function (dot, i) {
          dot.setAttribute('aria-current', i === idx ? 'true' : 'false');
        });
      }

      if (prev) prev.addEventListener('click', function () { scrollToSlide(Math.max(0, currentIndex() - 1)); });
      if (next) next.addEventListener('click', function () { scrollToSlide(Math.min(slides.length - 1, currentIndex() + 1)); });
      viewport.addEventListener('scroll', function () { window.requestAnimationFrame(update); }, { passive: true });

      update();
      track.dataset.fpReady = 'true';
    }

    function init(root) {
      root.querySelectorAll('.fp').forEach(initCarousel);
    }

    if (document.readyState !== 'loading') {
      init(document);
    } else {
      document.addEventListener('DOMContentLoaded', function () { init(document); });
    }
    document.addEventListener('shopify:section:load', function (event) { init(event.target); });
  })();
</script>

{% schema %}
{
  "name": "Featured products",
  "tag": "section",
  "class": "section-featured-products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore our air dried food"
    },
    {
      "type": "checkbox",
      "id": "uppercase_heading",
      "label": "Uppercase heading and titles",
      "default": true
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "Products",
      "limit": 12
    },
    {
      "type": "header",
      "content": "Card content (metafields)"
    },
    {
      "type": "text",
      "id": "metafield_labels",
      "label": "Labels metafield",
      "info": "namespace.key — single line text, comma separated.",
      "default": "custom.labels"
    },
    {
      "type": "text",
      "id": "metafield_description",
      "label": "Short description metafield",
      "info": "namespace.key — single line text.",
      "default": "custom.product_card_short_description"
    },
    {
      "type": "text",
      "id": "metafield_recipes_link",
      "label": "Recipes link metafield",
      "info": "namespace.key — URL. Falls back to the product page.",
      "default": "custom.recipes_link"
    },
    {
      "type": "text",
      "id": "recipes_label",
      "label": "Recipes link label",
      "default": "+ View all recipes"
    },
    {
      "type": "text",
      "id": "shop_label",
      "label": "Shop button label",
      "default": "Shop now"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FFF9EF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "card_border",
      "label": "Card border",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label pill",
      "default": "#661D1D"
    }
  ],
  "presets": [
    {
      "name": "Featured products"
    }
  ]
}
{% endschema %}
