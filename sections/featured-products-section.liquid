{% comment %} required--js--code {% endcomment %}
<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.fp-slider').forEach(function (slider) {
      const wrapper = slider.closest('.fp');

      const splide = new Splide(slider, {
        mediaQuery: 'max',
        destroy: true,

        breakpoints: {
          990: {
            destroy: false,
            type: 'slide',
            perPage: 1,
            focus: 'center',
            gap: '12px',
            speed: 600,
            drag: true,
            trimSpace: false,

            arrows: false,
            pagination: true,
          },
        },
      });
      
      splide.mount();

      function setActiveSlide(index) {
  slider.querySelectorAll('.splide__slide').forEach((slide, i) => {
    slide.classList.toggle('my-active', i === index);
  });
}

splide.on('mounted', () => {
  setActiveSlide(splide.index);
});

splide.on('move', (newIndex) => {
  setActiveSlide(newIndex);
});
      

      const prevBtn = wrapper.querySelector('.splide__arrow--prev');
      const nextBtn = wrapper.querySelector('.splide__arrow--next');
      function updateArrows() {
  if (prevBtn) {
    const isFirst = splide.index === 0;
    prevBtn.disabled = isFirst;
    prevBtn.classList.toggle("is-disabled", isFirst);
  }

  if (nextBtn) {
    const isLast = splide.index >= splide.length - splide.options.perPage;
    nextBtn.disabled = isLast;
    nextBtn.classList.toggle("is-disabled", isLast);
  }
}

splide.on("mounted move", updateArrows);

// Initial load par bhi check kare
setTimeout(updateArrows, 0);
      const customPagination = wrapper.querySelector('.fp__dots');

      if (prevBtn) {
        prevBtn.addEventListener('click', function () {
          splide.go('<');
        });
      }

      if (nextBtn) {
        nextBtn.addEventListener('click', function () {
          splide.go('>');
        });
      }

      if (customPagination) {
        const defaultPagination = slider.querySelector('.splide__pagination');

        if (defaultPagination) {
          customPagination.innerHTML = defaultPagination.innerHTML;
          defaultPagination.remove();

          customPagination.querySelectorAll('.splide__pagination__page').forEach(function (dot, index) {
            dot.addEventListener('click', function () {
              splide.go(index);
            });
          });

          splide.on('move', function (newIndex) {
            customPagination.querySelectorAll('.splide__pagination__page').forEach(function (dot, index) {
              dot.classList.toggle('is-active', index === newIndex);
            });
          });
        }
      }
    });

    document.querySelectorAll('.fp__recipes').forEach(function (button) {
      button.addEventListener('click', function (e) {
        e.preventDefault();

        const popup = document.getElementById(this.dataset.popup);

        if (popup) {
          popup.classList.add('active');
        }
      });
    });

    document.querySelectorAll('.fp-popup').forEach(function (popup) {
      popup.querySelector('.fp-popup__close').addEventListener('click', function () {
        popup.classList.remove('active');
      });

      popup.querySelector('.fp-popup__overlay').addEventListener('click', function () {
        popup.classList.remove('active');
      });
    });

    document.querySelectorAll('.fp-popup').forEach(function (popup) {
      const tabs = popup.querySelectorAll('.fp-popup__tabs button');
      const contents = popup.querySelectorAll('.fp-popup__content');

      tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
          tabs.forEach(function (btn) {
            btn.classList.remove('active');
          });

          contents.forEach(function (content) {
            content.classList.remove('active');
          });

          tab.classList.add('active');

          popup.querySelector('[data-content="' + tab.dataset.tab + '"]').classList.add('active');
        });
      });
    });
  });
</script>

{% schema %}
{
  "name": "Featured products",
  "tag": "section",
  "class": "section-featured-products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore our air dried food"
    },
    {
      "type": "checkbox",
      "id": "uppercase_heading",
      "label": "Uppercase heading and titles",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "Products",
      "limit": 12
    },
    {
      "type": "header",
      "content": "Card content (metafields)"
    },
    {
      "type": "text",
      "id": "metafield_labels",
      "label": "Labels metafield",
      "info": "namespace.key — single line text, comma separated.",
      "default": "custom.labels"
    },
    {
      "type": "text",
      "id": "metafield_description",
      "label": "Short description metafield",
      "info": "namespace.key — single line text.",
      "default": "custom.product_card_short_description"
    },
    {
      "type": "text",
      "id": "metafield_recipes_link",
      "label": "Recipes link metafield",
      "info": "namespace.key — URL. Falls back to the product page.",
      "default": "custom.recipes_link"
    },
    {
      "type": "text",
      "id": "recipes_label",
      "label": "Recipes link label",
      "default": "+ View all recipes"
    },
    {
      "type": "text",
      "id": "shop_label",
      "label": "Shop button label",
      "default": "Shop now"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FFF9EF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "card_border",
      "label": "Card border",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label pill",
      "default": "#661D1D"
    }
  ],
  "blocks": [
    {
      "type": "popup",
      "name": "Popup",
      "settings": [
        {
          "type": "text",
          "id": "popup_title",
          "label": "Popup Title"
        },
        {
          "type": "textarea",
          "id": "popup_subtitle",
          "label": "Popup Subtitle"
        },
        {
          "type": "image_picker",
          "id": "popup_image",
          "label": "Popup Right Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured products"
    }
  ]
}
{% endschema %}
