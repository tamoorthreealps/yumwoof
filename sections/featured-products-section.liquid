            <path d="M26.6 8.36C26.6 8.68 26.92 8.76 27.32 9.04C27.8 9.4 28.2 9.96 28.2 10.92C28.2 13.84 28.24 14.2 28.56 14.72C28.8 15.12 29.16 15.52 29.16 16C29.16 16.32 29 16.64 28.68 17.04C28.24 17.6 28.2 18.16 28.2 18.68V21.04C28.2 22.96 26.6 23.04 26.6 23.6C26.6 23.96 26.8 24.08 27.36 24.08C28.92 24.08 29.88 23.16 29.88 21.36V19.2C29.88 18.68 30 17.96 30.2 17.64C30.36 17.4 30.6 17.12 31 16.84C31.36 16.6 31.72 16.36 31.72 16C31.72 15.6 31.48 15.4 30.76 14.92C30.08 14.48 29.88 13.4 29.88 13.12V10.64C29.88 8.96 28.96 7.92 27.56 7.92C26.68 7.92 26.6 8.08 26.6 8.36Z" fill="black"/>
