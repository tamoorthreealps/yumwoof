{{ 'css--featured-products-section.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} .fp {
    --fp-bg: {{ section.settings.background_color }};
    --fp-text: {{ section.settings.text_color }};
    --fp-card-bg: {{ section.settings.card_background }};
    --fp-card-border: {{ section.settings.card_border }};
    --fp-label: {{ section.settings.label_color }};
  }
{%- endstyle -%}

{%- comment -%} Metafield keys come from settings as "namespace.key". {%- endcomment -%}
{%- assign labels_parts = section.settings.metafield_labels | split: '.' -%}
{%- assign desc_parts = section.settings.metafield_description | split: '.' -%}
{%- assign recipes_parts = section.settings.metafield_recipes_link | split: '.' -%}
{%- assign products = section.settings.products -%}

<section class="fp{% if section.settings.uppercase_heading %} fp--uppercase{% endif %}">
  <div class="fp__inner">
    <div class="fp__inner__head">
      {%- if section.settings.heading != blank -%}
        <h2 class="fp__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a
          href="{{ section.settings.button_link | default: '#' }}"
          class="fp__button desktop_fp__button"
        >
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>
    <div class="splide fp-slider">
      <div class="splide__track fp__viewport" data-fp-viewport>
        <ul class="splide__list fp__track" data-fp-track role="list">
          {%- if products.size > 0 -%}
            {%- for product in products -%}
              {% assign popup = section.blocks[forloop.index0] %}
              {%- assign labels_mf = product.metafields[labels_parts[0]][labels_parts[1]] -%}
              {%- assign desc_mf = product.metafields[desc_parts[0]][desc_parts[1]] -%}
              {%- assign recipes_mf = product.metafields[recipes_parts[0]][recipes_parts[1]] -%}
              {%- comment -%} A "list" metafield already returns an array; a plain text one is comma separated. {%- endcomment -%}
              {%- if labels_mf.type contains 'list' -%}
                {%- assign labels_list = labels_mf.value -%}
              {%- else -%}
                {%- assign labels_list = labels_mf.value | split: ',' -%}
              {%- endif -%}
              {%- assign recipes_url = recipes_mf.value | default: product.url -%}
              {% assign hover_media = product.metafields.custom.featured_hover_media.value %}
              <li class="splide__slide fp__card {% if hover_media %}fp__card__hover{% endif %}" data-fp-slide>
                <div class="fp__hover-media">
                  {% if hover_media %}
                    {% if hover_media.media_type == 'image' %}
                      {{ hover_media | image_url: width: 1200 | image_tag: class: 'fp__hover-image' }}
                    {% elsif hover_media.media_type == 'video' %}
                      {{
                        hover_media
                        | video_tag:
                          autoplay: true,
                          loop: true,
                          muted: true,
                          playsinline: true,
                          class: 'fp__hover-video'
                      }}
                    {% endif %}
                  {% endif %}
                </div>
                <h3 class="fp__title">{{ product.title }}</h3>

                {%- if labels_list.size > 0 -%}
                  <ul class="fp__labels" role="list">
                    {%- for label in labels_list -%}
                      {%- assign label_text = label | strip -%}
                      {%- if label_text != blank -%}
                        <li class="fp__label">{{ label_text }}</li>
                      {%- endif -%}
                    {%- endfor -%}
                  </ul>
                {%- endif -%}

                <a class="fp__media" href="{{ product.url }}" tabindex="-1" aria-hidden="true">
                  {%- if product.featured_image -%}
                    {%- assign fp_alt = product.featured_image.alt | default: product.title -%}
                    {{
                      product.featured_image
                      | image_url: width: 600
                      | image_tag: class: 'fp__img', widths: '200, 300, 460, 600', alt: fp_alt, loading: 'lazy'
                    }}
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'fp__img fp__img--placeholder' }}
                  {%- endif -%}
                </a>

                {%- if desc_mf.value != blank -%}
                  <p class="fp__desc">{{ desc_mf.value }}</p>
                {%- endif -%}

                {%- if section.settings.recipes_label != blank -%}
                  <a class="fp__recipes" href="#" data-popup="popup-{{ forloop.index }}">
                    {{- section.settings.recipes_label -}}
                  </a>
                {%- endif -%}

                <a class="fp__shop" href="{{ product.url }}">
                  <span class="fp__shop-label">{{ section.settings.shop_label }}</span>
                </a>
              </li>
            {%- endfor -%}
          {%- else -%}
            {%- comment -%} Editor placeholders when no products are selected. {%- endcomment -%}
            {%- for i in (1..3) -%}
              <li class="fp__card" data-fp-slide>
                <h3 class="fp__title">{{ 'onboarding.product_title' | t }}</h3>
                <ul class="fp__labels" role="list">
                  <li class="fp__label">Grain-Free</li>
                  <li class="fp__label">Organ-Rich</li>
                </ul>
                <span class="fp__media">{{ 'product-1' | placeholder_svg_tag: 'fp__img fp__img--placeholder' }}</span>
                <p class="fp__desc">{{ 'onboarding.product_description' | t | truncatewords: 8 }}</p>
                <span class="fp__recipes">{{ section.settings.recipes_label }}</span>
                <span class="fp__shop"
                  ><span class="fp__shop-label">{{ section.settings.shop_label }}</span></span
                >
              </li>
            {%- endfor -%}
          {%- endif -%}
        </ul>
      </div>
    </div>

    {%- if products.size > 1 -%}
      <div class="fp__nav splide__arrows">
        <button
          class="fp__arrow splide__arrow splide__arrow--prev"
          aria-label="{{ 'general.slider.previous_slide' | t | default: 'Previous' }}"
        >
          <svg width="16" height="8" viewBox="0 0 16 8" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5.96542 8C5.67819 7.33884 5.37993 6.75482 5.07061 6.24793C4.76129 5.71901 4.45197 5.26722 4.14265 4.89256H16V3.10744H4.14265C4.45197 2.71074 4.76129 2.25895 5.07061 1.75207C5.37993 1.22314 5.67819 0.639119 5.96542 0H4.40778C3.01585 1.60882 1.54659 2.7989 0 3.57025V4.42975C1.54659 5.17906 3.01585 6.36915 4.40778 8H5.96542Z" fill="black"/>
          </svg>
        </button>

        <ul class="fp__dots splide__pagination"></ul>

        <button
          class="fp__arrow splide__arrow splide__arrow--next"
          aria-label="{{ 'general.slider.next_slide' | t | default: 'Next' }}"
        >
          <svg width="16" height="8" viewBox="0 0 16 8" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M10.0346 8C10.3218 7.33884 10.6201 6.75482 10.9294 6.24793C11.2387 5.71901 11.548 5.26722 11.8573 4.89256H0V3.10744H11.8573C11.548 2.71074 11.2387 2.25895 10.9294 1.75207C10.6201 1.22314 10.3218 0.639119 10.0346 0H11.5922C12.9841 1.60882 14.4534 2.7989 16 3.57025V4.42975C14.4534 5.17906 12.9841 6.36915 11.5922 8H10.0346Z" fill="black"/>
          </svg>
        </button>
      </div>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <div class="mobile_fp__button">
        <a
          href="{{ section.settings.button_link | default: '#' }}"
          class="fp__button"
        >
          {{ section.settings.button_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% comment %} popup--html--code {% endcomment %}
