{{ 'css--comparison-section.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} .cmp {
    --cmp-bg: {{ section.settings.background_color }};
    --cmp-text: {{ section.settings.text_color }};
    --cmp-highlight: {{ section.settings.highlight_color }};
    --cmp-accent: {{ section.settings.accent_color }};
  }
{%- endstyle -%}

{%- capture check_mark -%}
  <span class="cmp__mark cmp__mark--yes">
    <svg width="24" height="20" viewBox="0 0 24 20" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M23.4243 0C23.7153 0.00365881 23.8409 0.162039 23.9942 0.379971C23.9992 0.543226 24.0274 0.706948 23.8913 0.826462C22.8435 1.73548 21.4272 2.50501 20.2851 3.29439C14.4562 7.32363 9.72632 12.8296 6.28543 18.9321C5.72317 19.9292 3.4475 20.4297 2.5119 19.5321C0.804528 17.8941 0.256041 14.8933 0.0388062 12.6308C-0.0111192 11.3681 -0.0852151 9.69894 0.341925 8.49756C0.500319 8.05218 1.19432 7.60845 1.66911 7.87118C2.29387 8.21702 2.39174 9.31252 2.58847 9.93656C3.10426 12.0389 3.58371 14.1236 4.29832 16.173C7.80043 9.87448 16.3263 2.08215 23.4243 0Z" fill="black"/>
    </svg>
    <span class="visually-hidden">Yes</span>
  </span>
{%- endcapture -%}
{%- capture cross_mark -%}
  <span class="cmp__mark cmp__mark--no">    
    <svg width="16" height="20" viewBox="0 0 16 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M5.30748 9.78104C3.55589 7.42642 0.574904 3.65157 0.148273 0.706683C0.0163384 -0.204093 1.59074 -0.2261 2.32106 0.592004C4.16355 2.656 5.6704 5.0203 7.34066 7.24668C8.68342 5.48214 10.1611 3.82724 11.7597 2.29746C12.1458 1.92127 12.604 1.54594 13.0163 1.19299C13.5672 0.750123 14.5352 0.00439346 15.2089 0.6695C15.4554 1.20333 15.1696 1.66574 14.85 2.10282C14.2288 2.89901 13.5935 3.68382 12.945 4.45697C11.6154 6.08824 10.297 7.72843 8.98889 9.37745C10.3185 10.934 11.666 12.4745 13.0313 13.9988C13.6178 14.6611 17.8457 18.7951 15.0571 18.926C14.4855 18.9527 13.1568 18.0145 12.7098 17.6285C10.7711 15.9265 8.79399 14.0003 7.13263 12.0263C6.00669 13.3999 5.15765 15.0189 4.17142 16.4891C3.45206 17.5615 2.31872 19.8643 0.928445 19.9958C0.698216 20.0189 0.468642 19.9457 0.293043 19.7934C-0.3983 19.1952 0.314035 17.773 0.591584 17.0871C0.847394 16.5329 1.23073 15.8757 1.52927 15.3315C2.63609 13.4345 3.98449 11.5246 5.30748 9.78104Z" fill="black" fill-opacity="0.25"/>
    </svg>
    <span class="visually-hidden">No</span>
  </span>
{%- endcapture -%}

{%- assign row_blocks = section.blocks | where: 'type', 'row' -%}

<section class="cmp{% if section.settings.uppercase_heading %} cmp--uppercase{% endif %}">
  <div class="cmp__inner">
    <div class="cmp__intro">
      {%- if section.settings.eyebrow != blank -%}
        <p class="cmp__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="cmp__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="cmp__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Mobile competitor tabs {%- endcomment -%}
    <div class="cmp__tabs" role="tablist" data-cmp-tabs>
      {%- for i in (1..3) -%}
        {%- assign label_key = 'comp' | append: i | append: '_label' -%}
        {%- assign icon_key = 'comp' | append: i | append: '_icon' -%}
        {%- assign clabel = section.settings[label_key] -%}
        {%- if clabel != blank -%}
          {%- assign cicon = section.settings[icon_key] -%}
          <button type="button" class="cmp__tab" role="tab" data-comp-index="{{ i }}">
            {%- if cicon != blank -%}
              {{
                cicon
                | image_url: width: 80
                | image_tag: class: 'cmp__tab-icon', alt: '', widths: '40, 60, 80', loading: 'lazy'
              }}
            {%- endif -%}
            <span>{{ clabel }}</span>
          </button>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="cmp__scroll">
      <div class="cmp__table">
        {%- comment -%} Row-label column {%- endcomment -%}
        <div class="cmp__col cmp__col--labels">
          <div class="cmp__head cmp__head--empty" aria-hidden="true"></div>
          {%- for block in row_blocks -%}
            <div class="cmp__cell cmp__cell--label" {{ block.shopify_attributes }}>{{ block.settings.label }}</div>
          {%- endfor -%}
        </div>

        {%- comment -%} Brand column (highlighted) {%- endcomment -%}
        <div class="cmp__col cmp__col--brand">
          <div class="cmp__head">
            {%- if section.settings.brand_logo != blank -%}
              {{
                section.settings.brand_logo
                | image_url: width: 260
                | image_tag:
                  class: 'cmp__brand-logo',
                  alt: section.settings.brand_label,
                  widths: '130, 200, 260',
                  loading: 'lazy'
              }}
            {%- endif -%}
            {%- if section.settings.brand_icon != blank -%}
              {{
                section.settings.brand_icon
                | image_url: width: 160
                | image_tag: class: 'cmp__col-icon', alt: '', widths: '80, 120, 160', loading: 'lazy'
              }}
            {%- endif -%}
            <span class="cmp__col-label cmp__col-label--brand">{{ section.settings.brand_label }}</span>
          </div>
          {%- for block in row_blocks -%}
            <div class="cmp__cell">
              {%- assign v = block.settings.brand_value | strip | downcase -%}
              {%- if v == 'check' -%}
                {{ check_mark }}
              {%- elsif v == 'cross' -%}
                {{ cross_mark }}
              {%- elsif block.settings.brand_value != blank -%}
                <span class="cmp__cost">{{ block.settings.brand_value }}</span>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>

        {%- comment -%} Competitor columns {%- endcomment -%}
        {%- for i in (1..3) -%}
          {%- assign label_key = 'comp' | append: i | append: '_label' -%}
          {%- assign icon_key = 'comp' | append: i | append: '_icon' -%}
          {%- assign value_key = 'comp' | append: i | append: '_value' -%}
          {%- assign clabel = section.settings[label_key] -%}
          {%- if clabel != blank -%}
            {%- assign cicon = section.settings[icon_key] -%}
            <div class="cmp__col cmp__col--comp" data-comp-index="{{ i }}">
              <div class="cmp__head">
                {%- if cicon != blank -%}
                  {{
                    cicon
                    | image_url: width: 160
                    | image_tag: class: 'cmp__col-icon', alt: '', widths: '80, 120, 160', loading: 'lazy'
                  }}
                {%- endif -%}
                <span class="cmp__col-label">{{ clabel }}</span>
              </div>
              {%- for block in row_blocks -%}
                {%- assign cv = block.settings[value_key] -%}
                <div class="cmp__cell">
                  {%- assign v = cv | strip | downcase -%}
                  {%- if v == 'check' -%}
                    {{ check_mark }}
                  {%- elsif v == 'cross' -%}
                    {{ cross_mark }}
                  {%- elsif cv != blank -%}
                    <span class="cmp__cost">{{ cv }}</span>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    function initComparison(section) {
      var table = section.querySelector('.cmp__table');
      if (!table || table.dataset.cmpReady) return;
      var tabs = Array.prototype.slice.call(section.querySelectorAll('.cmp__tab'));
      var cols = Array.prototype.slice.call(section.querySelectorAll('.cmp__col--comp'));
      if (tabs.length === 0) return;

      function activate(index) {
        tabs.forEach(function (t) {
          t.setAttribute('aria-selected', t.dataset.compIndex === index ? 'true' : 'false');
        });
        cols.forEach(function (c) {
          c.classList.toggle('is-active', c.dataset.compIndex === index);
        });
      }

      tabs.forEach(function (t) {
        t.addEventListener('click', function () {
          activate(t.dataset.compIndex);
        });
      });
      activate(tabs[0].dataset.compIndex);
      table.dataset.cmpReady = 'true';
    }

    function init(root) {
      root.querySelectorAll('.cmp').forEach(initComparison);
    }

    if (document.readyState !== 'loading') {
      init(document);
    } else {
      document.addEventListener('DOMContentLoaded', function () {
        init(document);
      });
    }
    document.addEventListener('shopify:section:load', function (event) {
      init(event.target);
    });
  })();
</script>

