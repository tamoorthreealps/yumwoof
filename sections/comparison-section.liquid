    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Air-dried because your dog nose the difference"
    },
    {
      "type": "checkbox",
      "id": "uppercase_heading",
      "label": "Uppercase eyebrow and heading",
      "default": true
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Cooked at low temperatures to preserve whole food nutrition and flavor."
    },
    {
      "type": "header",
      "content": "Your brand column (highlighted)"
    },
    {
      "type": "text",
      "id": "brand_label",
      "label": "Label",
      "default": "Air-Dried"
    },
    {
      "type": "image_picker",
      "id": "brand_logo",
      "label": "Logo"
    },
    {
      "type": "image_picker",
      "id": "brand_icon",
      "label": "Icon"
    },
    {
      "type": "header",
      "content": "Competitor 1"
    },
    {
      "type": "text",
      "id": "comp1_label",
      "label": "Label",
      "default": "Dry Kibble"
    },
    {
      "type": "image_picker",
      "id": "comp1_icon",
      "label": "Icon"
    },
    {
      "type": "header",
      "content": "Competitor 2"
    },
    {
      "type": "text",
      "id": "comp2_label",
      "label": "Label",
      "default": "Raw"
    },
    {
      "type": "image_picker",
      "id": "comp2_icon",
      "label": "Icon"
    },
    {
      "type": "header",
      "content": "Competitor 3"
    },
    {
      "type": "text",
      "id": "comp3_label",
      "label": "Label",
      "default": "Fresh"
    },
    {
      "type": "image_picker",
      "id": "comp3_icon",
      "label": "Icon"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FFF9EF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Brand column highlight",
      "default": "#C8912A"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Brand accent (logo, label, cost)",
      "default": "#661D1D"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Row",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Feature",
          "default": "Seed Oil Free"
        },
        {
          "type": "paragraph",
          "content": "For each column enter \"check\", \"cross\", or custom text like \"$$\"."
        },
        {
          "type": "text",
          "id": "brand_value",
          "label": "Your brand",
          "default": "check"
        },
        {
          "type": "text",
          "id": "comp1_value",
          "label": "Competitor 1",
          "default": "cross"
        },
        {
          "type": "text",
          "id": "comp2_value",
          "label": "Competitor 2",
          "default": "check"
        },
        {
          "type": "text",
          "id": "comp3_value",
          "label": "Competitor 3",
          "default": "check"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Comparison table",
      "blocks": [
        { "type": "row", "settings": { "label": "Seed Oil Free", "brand_value": "check", "comp1_value": "cross", "comp2_value": "check", "comp3_value": "check" } },
        { "type": "row", "settings": { "label": "Minimally Processed", "brand_value": "check", "comp1_value": "check", "comp2_value": "cross", "comp3_value": "cross" } },
        { "type": "row", "settings": { "label": "Non-GMO", "brand_value": "check", "comp1_value": "cross", "comp2_value": "cross", "comp3_value": "cross" } },
        { "type": "row", "settings": { "label": "Fridge Free", "brand_value": "check", "comp1_value": "cross", "comp2_value": "cross", "comp3_value": "check" } },
        { "type": "row", "settings": { "label": "Daily Cost", "brand_value": "$$", "comp1_value": "$", "comp2_value": "$$$", "comp3_value": "$$$" } }
