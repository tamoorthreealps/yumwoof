{{ 'header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'header.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>
{%- style -%}
  #shopify-section-{{ section.id }} .yw-header {
    --yw-nav-bg: {{ section.settings.navbar_bg }};
    --yw-nav-text: {{ section.settings.navbar_text_color }};
    --yw-nav-border: {{ section.settings.navbar_border_color }};
    --yw-cta-bg: {{ section.settings.cta_bg_color }};
    --yw-cta-text: {{ section.settings.cta_text_color }};
    --yw-topbar-bg: {{ section.settings.announcement_bg }};
    --yw-topbar-text: {{ section.settings.announcement_text_color }};
    --yw-mobile-bg: {{ section.settings.mobile_menu_bg }};
  }
{%- endstyle -%}

{%- liquid
  assign mobile_id = 'MobileMenu-' | append: section.id
-%}

<yw-header
  class="yw-header{% if section.settings.enable_sticky %}{% if request.page_type == 'index' %} yw-header--fixed{% else %} yw-header--sticky{% endif %}{% endif %}"
  data-mobile-target="{{ mobile_id }}"
  {% if section.settings.enable_sticky %}
    data-sticky
  {% endif %}
>
  {%- comment -%} ---------------- Announcement topbar ---------------- {%- endcomment -%}
  {%- if section.settings.show_announcement and section.settings.announcement_text != blank -%}
    <div class="yw-topbar" role="region" aria-label="{{ 'sections.header.announcement' | t }}">
      <div class="yw-topbar__inner">
        {%- if section.settings.announcement_link != blank -%}
          <a class="yw-topbar__link" href="{{ section.settings.announcement_link }}">
            {{- section.settings.announcement_text -}}
          </a>
        {%- else -%}
          <p class="yw-topbar__text">{{ section.settings.announcement_text }}</p>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ---------------- Navbar ---------------- {%- endcomment -%}
  <div class="yw-nav-outer">
    <nav class="yw-nav" aria-label="{{ 'sections.header.menu' | t }}">
      {%- comment -%} Mobile hamburger toggle (opens the overlay) {%- endcomment -%}
      <button
        type="button"
        class="yw-nav__toggle"
        aria-expanded="false"
        aria-controls="{{ mobile_id }}"
        aria-label="{{ 'sections.header.menu' | t }}"
      >
        <span class="svg-wrapper">
          <svg width="24" height="16" viewBox="0 0 24 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M23 0C23.5523 0 24 0.447715 24 1C24 1.55228 23.5523 2 23 2H1C0.447715 2 0 1.55228 0 1C0 0.447715 0.447715 0 1 0H23Z" fill="black"/>
            <path d="M23 7C23.5523 7 24 7.44772 24 8C24 8.55228 23.5523 9 23 9H1C0.447715 9 0 8.55228 0 8C0 7.44772 0.447715 7 1 7H23Z" fill="black"/>
            <path d="M23 14C23.5523 14 24 14.4477 24 15C24 15.5523 23.5523 16 23 16H1C0.447715 16 0 15.5523 0 15C0 14.4477 0.447715 14 1 14H23Z" fill="black"/>
          </svg>
        </span>
      </button>

      {%- comment -%} Left: navigation links (with optional mega dropdowns) {%- endcomment -%}
      <ul class="yw-nav__links">
        {%- if section.settings.cta_text != blank -%}
          {%- assign cta_mega = blank -%}
          {%- assign cta_needle = section.settings.cta_text | downcase | strip -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'mega_menu' and block.settings.title != blank -%}
              {%- assign hay = block.settings.title | downcase | strip -%}
              {%- if hay == cta_needle -%}{%- assign cta_mega = block -%}{%- endif -%}
            {%- endif -%}
          {%- endfor -%}
          <li class="yw-nav__item{% if cta_mega != blank %} yw-nav__item--mega{% endif %}">
            <a
              class="yw-nav__cta"
              href="{{ section.settings.cta_link | default: routes.all_products_collection_url }}"
              {% if cta_mega != blank %}
                aria-haspopup="true" aria-expanded="false"
              {% endif %}
            >
              {{- section.settings.cta_text -}}
            </a>
            {%- if cta_mega != blank -%}
              <div class="yw-mega-main">
                <div class="yw-mega" {{ cta_mega.shopify_attributes }}>
                  <div class="yw-mega__inner">{% render 'header-mega-content', block: cta_mega %}</div>
                </div>
              </div>
            {%- endif -%}
          </li>
        {%- endif -%}

        {%- if section.settings.menu != blank -%}
          {%- for link in section.settings.menu.links -%}
            {%- assign link_mega = blank -%}
            {%- assign link_needle = link.title | downcase | strip -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'mega_menu' and block.settings.title != blank -%}
                {%- assign hay = block.settings.title | downcase | strip -%}
                {%- if hay == link_needle -%}{%- assign link_mega = block -%}{%- endif -%}
              {%- endif -%}
            {%- endfor -%}
            <li class="yw-nav__item{% if link_mega != blank %} yw-nav__item--mega{% endif %}">
              <a
                class="yw-nav__link"
                href="{{ link.url }}"
                {% if link_mega != blank %}
                  aria-haspopup="true" aria-expanded="false"
                {% endif %}
              >
                {{- link.title -}}
              </a>
              {%- if link_mega != blank -%}
                <div class="yw-mega" {{ link_mega.shopify_attributes }}>
                  <div class="yw-mega__inner">{% render 'header-mega-content', block: link_mega %}</div>
                </div>
              {%- endif -%}
            </li>
          {%- endfor -%}
        {%- endif -%}
      </ul>

      {%- comment -%} Center: logo {%- endcomment -%}
      <a href="{{ routes.root_url }}" class="yw-nav__logo" aria-label="{{ shop.name | escape }}">
        {%- if settings.logo != blank -%}
          {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
          {{
            settings.logo
            | image_url: width: 400
            | image_tag: widths: '200, 300, 400', alt: logo_alt, loading: 'eager'
          }}
        {%- else -%}
          {{ 'yumwoof-logo.svg' | inline_asset_content }}
          <span class="visually-hidden">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      {%- comment -%} Right: membership + account + cart {%- endcomment -%}
      <div class="yw-nav__actions">
        {%- if section.settings.membership_text != blank -%}
          <a class="yw-nav__membership" href="{{ section.settings.membership_link | default: '#' }}">
            {{- section.settings.membership_text -}}
          </a>
        {%- endif -%}

        <div class="yw-nav__icons">
          {%- if shop.customer_accounts_enabled -%}
            <a
              href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
              class="yw-nav__icon yw-icon--account link focus-inset"
              rel="nofollow"
            >
              <span class="svg-wrapper">{{ 'login--icon.svg' | inline_asset_content }}</span>
              <span class="visually-hidden">
                {%- liquid
                  if customer
                    echo 'customer.account_fallback' | t
                  else
                    echo 'customer.log_in' | t
                  endif
                -%}
              </span>
            </a>
          {%- endif -%}

          <a
            href="{{ routes.cart_url }}"
            class="yw-nav__icon yw-icon--cart link focus-inset"
            id="cart-icon-bubble"
          >
            {% if cart == empty %}
              <span class="svg-wrapper">
                <svg width="23" height="28" viewBox="0 0 23 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M22.5959 23.5055C22.5399 22.8895 22.4838 22.3156 22.4838 21.1116C22.4838 18.6476 22.5119 18.6476 22.5119 16.1837C22.5119 14.9377 22.5119 14.3357 22.5119 13.7057C22.5119 13.0757 22.5119 12.4738 22.4698 11.2698V11.1298C22.4698 10.8638 22.4838 10.7238 22.5119 10.5558C22.5259 10.4018 22.5539 10.2198 22.5539 9.9678C22.5539 9.81381 22.5539 9.64581 22.5259 9.43581C22.3718 7.97984 22.2317 7.23786 22.1056 6.52387C21.9795 5.80988 21.8534 5.1239 21.7414 3.68193C21.7274 3.49993 21.7274 3.37393 21.7274 3.26194C21.7274 3.03794 21.7414 2.91194 21.7694 2.71595C21.7974 2.51995 21.8254 2.26796 21.8254 1.90396V1.77796C21.7554 0.811984 20.9429 0.0699986 19.9623 0H19.8502C19.458 0 19.2198 0.0419992 19.0237 0.0699986C18.8276 0.0979981 18.6875 0.125997 18.3233 0.125997H18.1832C16.0539 0.125997 16.0119 0.0699986 13.7565 0.0699986H13.7425C11.4731 0.0699986 11.4591 0.0839983 9.18966 0.0839983C6.92026 0.0839983 6.92026 0.0139997 4.62284 0.0139997H4.59483C4.13254 0.0139997 3.88039 0.0419992 3.65625 0.0699986C3.43211 0.0979981 3.25 0.111998 2.81573 0.125997C2.29741 0.139997 1.82112 0.321994 1.44289 0.629987C1.06466 0.937981 0.798491 1.39997 0.798491 1.93196C0.798491 2.67395 0.868534 2.88394 0.854526 3.23394C0.854526 3.37393 0.854526 3.54193 0.826509 3.80792C0.574353 6.76187 0.686422 6.74787 0.350216 9.65981C0.30819 10.1638 0.0560344 10.7378 0.0420258 11.4658C0.0420258 13.9017 0.070043 13.9017 0.070043 16.3097V16.3517C0.070043 18.6896 0 18.7316 0 21.1116V21.1536C0 22.3856 0.070043 23.0155 0.126077 23.6315C0.182112 24.2335 0.252155 24.8075 0.252155 25.9975C0.252155 26.5295 0.462284 27.0195 0.798491 27.3835C1.1347 27.7614 1.63901 28.0134 2.19935 27.9994C5.26724 27.9994 5.26724 27.8874 8.30711 27.8874C11.375 27.8874 11.375 27.7754 14.4149 27.7754C17.4547 27.7754 17.4547 27.8034 20.5226 27.8034C21.0269 27.8034 21.5453 27.6495 21.9655 27.3555C22.3858 27.0755 22.75 26.6135 22.75 26.0115C22.75 24.7655 22.694 24.1215 22.6239 23.5055H22.5959ZM20.8028 14.0977C20.7468 14.6857 20.6767 15.3157 20.6767 16.5197C20.6767 18.9136 20.7888 18.9136 20.7888 21.2376V21.2656C20.7888 23.4915 20.9149 23.6455 20.9149 25.5495C20.9149 25.6755 20.9149 25.8015 20.9149 25.9415L20.7748 26.1235L20.4666 26.2495L2.21336 26.0955C2.04526 26.0955 1.91918 26.0395 1.86315 25.9975L1.77909 25.8295C1.77909 24.6535 1.83513 24.0935 1.89116 23.4915C1.9472 22.8895 2.00323 22.2596 2.00323 21.0556V21.0276C2.00323 18.6336 1.87716 18.6196 1.87716 16.3097V16.2817C1.87716 13.9157 1.9472 13.9157 1.9472 11.5218C1.9472 11.0318 2.01724 10.5838 2.07328 10.0378C2.31142 8.02184 2.18534 7.99384 2.40948 6.04788C2.45151 5.62789 2.49353 5.43189 2.53556 5.2219C2.57759 5.0259 2.6056 4.8019 2.64763 4.43791C3.61422 4.43791 3.65625 4.50791 4.73491 4.50791H4.77694C7.10237 4.50791 7.10237 4.39591 9.37177 4.39591C10.5065 4.39591 11.0528 4.43791 11.6272 4.49391C12.2015 4.53591 12.8039 4.59191 13.9666 4.59191H13.9946C15.9558 4.59191 16.222 4.59191 17.7349 4.59191C17.9731 4.59191 18.2392 4.59191 18.5474 4.59191C18.9677 4.59191 19.2338 4.53591 19.43 4.49391C19.5981 4.46591 19.7101 4.43791 19.9343 4.42391C20.0043 5.0119 20.0323 5.0539 20.1024 5.62789C20.3685 7.85384 20.2845 7.85384 20.5647 10.1218C20.6767 10.8218 20.9009 11.3538 20.9009 11.8158C20.9009 12.9777 20.8448 13.5377 20.7748 14.1257L20.8028 14.0977ZM19.8642 2.78594C17.2306 2.78594 17.1185 2.65995 14.2748 2.65995C11.347 2.65995 11.347 2.68795 8.43319 2.68795C5.56142 2.68795 5.53341 2.61795 2.67565 2.61795C2.22737 2.61795 2.36746 1.74997 2.87177 1.80596C2.88578 1.80596 2.9278 1.80596 2.9278 1.80596H3.09591C3.5722 1.80596 3.85237 1.77796 4.10453 1.74997C4.35668 1.72197 4.58082 1.69397 5.05711 1.69397H5.08513C7.28448 1.69397 7.29849 1.72197 9.48384 1.72197H9.52586C10.6185 1.72197 11.1369 1.77796 11.6972 1.83396C12.2575 1.88996 12.8459 1.94596 13.9666 1.94596C15.0873 1.94596 15.6756 1.88996 16.236 1.83396C16.7963 1.77796 17.3147 1.72197 18.4073 1.72197H18.4494C19.1358 1.72197 19.1638 1.72197 19.8502 1.74997C19.8502 1.74997 20.2144 1.77796 20.3545 2.15596C20.4946 2.53395 20.0463 2.79994 19.8782 2.79994L19.8642 2.78594Z" fill="black"></path>
                </svg>
              </span>
              <span aria-hidden="true" class="cart-count-bubble">{{ cart.item_count }}</span>
            {% else %}
              <span class="svg-wrapper">
                <svg width="23" height="28" viewBox="0 0 23 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M22.5959 23.5055C22.5399 22.8895 22.4838 22.3156 22.4838 21.1116C22.4838 18.6476 22.5119 18.6476 22.5119 16.1837C22.5119 14.9377 22.5119 14.3357 22.5119 13.7057C22.5119 13.0757 22.5119 12.4738 22.4698 11.2698V11.1298C22.4698 10.8638 22.4838 10.7238 22.5119 10.5558C22.5259 10.4018 22.5539 10.2198 22.5539 9.9678C22.5539 9.81381 22.5539 9.64581 22.5259 9.43581C22.3718 7.97984 22.2317 7.23786 22.1056 6.52387C21.9795 5.80988 21.8534 5.1239 21.7414 3.68193C21.7274 3.49993 21.7274 3.37393 21.7274 3.26194C21.7274 3.03794 21.7414 2.91194 21.7694 2.71595C21.7974 2.51995 21.8254 2.26796 21.8254 1.90396V1.77796C21.7554 0.811984 20.9429 0.0699986 19.9623 0H19.8502C19.458 0 19.2198 0.0419992 19.0237 0.0699986C18.8276 0.0979981 18.6875 0.125997 18.3233 0.125997H18.1832C16.0539 0.125997 16.0119 0.0699986 13.7565 0.0699986H13.7425C11.4731 0.0699986 11.4591 0.0839983 9.18966 0.0839983C6.92026 0.0839983 6.92026 0.0139997 4.62284 0.0139997H4.59483C4.13254 0.0139997 3.88039 0.0419992 3.65625 0.0699986C3.43211 0.0979981 3.25 0.111998 2.81573 0.125997C2.29741 0.139997 1.82112 0.321994 1.44289 0.629987C1.06466 0.937981 0.798491 1.39997 0.798491 1.93196C0.798491 2.67395 0.868534 2.88394 0.854526 3.23394C0.854526 3.37393 0.854526 3.54193 0.826509 3.80792C0.574353 6.76187 0.686422 6.74787 0.350216 9.65981C0.30819 10.1638 0.0560344 10.7378 0.0420258 11.4658C0.0420258 13.9017 0.070043 13.9017 0.070043 16.3097V16.3517C0.070043 18.6896 0 18.7316 0 21.1116V21.1536C0 22.3856 0.070043 23.0155 0.126077 23.6315C0.182112 24.2335 0.252155 24.8075 0.252155 25.9975C0.252155 26.5295 0.462284 27.0195 0.798491 27.3835C1.1347 27.7614 1.63901 28.0134 2.19935 27.9994C5.26724 27.9994 5.26724 27.8874 8.30711 27.8874C11.375 27.8874 11.375 27.7754 14.4149 27.7754C17.4547 27.7754 17.4547 27.8034 20.5226 27.8034C21.0269 27.8034 21.5453 27.6495 21.9655 27.3555C22.3858 27.0755 22.75 26.6135 22.75 26.0115C22.75 24.7655 22.694 24.1215 22.6239 23.5055H22.5959ZM20.8028 14.0977C20.7468 14.6857 20.6767 15.3157 20.6767 16.5197C20.6767 18.9136 20.7888 18.9136 20.7888 21.2376V21.2656C20.7888 23.4915 20.9149 23.6455 20.9149 25.5495C20.9149 25.6755 20.9149 25.8015 20.9149 25.9415L20.7748 26.1235L20.4666 26.2495L2.21336 26.0955C2.04526 26.0955 1.91918 26.0395 1.86315 25.9975L1.77909 25.8295C1.77909 24.6535 1.83513 24.0935 1.89116 23.4915C1.9472 22.8895 2.00323 22.2596 2.00323 21.0556V21.0276C2.00323 18.6336 1.87716 18.6196 1.87716 16.3097V16.2817C1.87716 13.9157 1.9472 13.9157 1.9472 11.5218C1.9472 11.0318 2.01724 10.5838 2.07328 10.0378C2.31142 8.02184 2.18534 7.99384 2.40948 6.04788C2.45151 5.62789 2.49353 5.43189 2.53556 5.2219C2.57759 5.0259 2.6056 4.8019 2.64763 4.43791C3.61422 4.43791 3.65625 4.50791 4.73491 4.50791H4.77694C7.10237 4.50791 7.10237 4.39591 9.37177 4.39591C10.5065 4.39591 11.0528 4.43791 11.6272 4.49391C12.2015 4.53591 12.8039 4.59191 13.9666 4.59191H13.9946C15.9558 4.59191 16.222 4.59191 17.7349 4.59191C17.9731 4.59191 18.2392 4.59191 18.5474 4.59191C18.9677 4.59191 19.2338 4.53591 19.43 4.49391C19.5981 4.46591 19.7101 4.43791 19.9343 4.42391C20.0043 5.0119 20.0323 5.0539 20.1024 5.62789C20.3685 7.85384 20.2845 7.85384 20.5647 10.1218C20.6767 10.8218 20.9009 11.3538 20.9009 11.8158C20.9009 12.9777 20.8448 13.5377 20.7748 14.1257L20.8028 14.0977ZM19.8642 2.78594C17.2306 2.78594 17.1185 2.65995 14.2748 2.65995C11.347 2.65995 11.347 2.68795 8.43319 2.68795C5.56142 2.68795 5.53341 2.61795 2.67565 2.61795C2.22737 2.61795 2.36746 1.74997 2.87177 1.80596C2.88578 1.80596 2.9278 1.80596 2.9278 1.80596H3.09591C3.5722 1.80596 3.85237 1.77796 4.10453 1.74997C4.35668 1.72197 4.58082 1.69397 5.05711 1.69397H5.08513C7.28448 1.69397 7.29849 1.72197 9.48384 1.72197H9.52586C10.6185 1.72197 11.1369 1.77796 11.6972 1.83396C12.2575 1.88996 12.8459 1.94596 13.9666 1.94596C15.0873 1.94596 15.6756 1.88996 16.236 1.83396C16.7963 1.77796 17.3147 1.72197 18.4073 1.72197H18.4494C19.1358 1.72197 19.1638 1.72197 19.8502 1.74997C19.8502 1.74997 20.2144 1.77796 20.3545 2.15596C20.4946 2.53395 20.0463 2.79994 19.8782 2.79994L19.8642 2.78594Z" fill="black"></path>
                </svg>
              </span>
              <span aria-hidden="true" class="cart-count-bubble">{{ cart.item_count }}</span>
            {% endif %}
            <span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>
            {%- if cart != empty -%}
              <div class="cart-count-bubble">
                {%- if cart.item_count < 100 -%}
                  <span aria-hidden="true">{{ cart.item_count }}</span>
                {%- endif -%}
                <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
              </div>
            {%- endif -%}
          </a>
        </div>
      </div>
    </nav>
  </div>

  {%- comment -%} ---------------- Mobile menu overlay ---------------- {%- endcomment -%}
  <div class="yw-mobile-menu" id="{{ mobile_id }}">
    {%- comment -%} ---------------- Announcement topbar ---------------- {%- endcomment -%}
    {%- if section.settings.show_announcement and section.settings.announcement_text != blank -%}
      <div class="yw-topbar" role="region" aria-label="{{ 'sections.header.announcement' | t }}">
        <div class="yw-topbar__inner">
          {%- if section.settings.announcement_link != blank -%}
            <a class="yw-topbar__link" href="{{ section.settings.announcement_link }}">
              {{- section.settings.announcement_text -}}
            </a>
          {%- else -%}
            <p class="yw-topbar__text">{{ section.settings.announcement_text }}</p>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
    <div class="yw-mobile-menu__bar">
      <button
        type="button"
        class="yw-mobile-menu__close"
        aria-label="{{ 'accessibility.close' | t | default: 'Close' }}"
      >
        <span class="svg-wrapper">{{ 'icon-close.svg' | inline_asset_content }}</span>
      </button>

      <a href="{{ routes.root_url }}" class="yw-nav__logo" aria-label="{{ shop.name | escape }}">
        {%- if settings.logo != blank -%}
          {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
          {{
            settings.logo
            | image_url: width: 300
            | image_tag: widths: '150, 220, 300', alt: logo_alt, loading: 'lazy'
          }}
        {%- else -%}
          {{ 'yumwoof-logo.svg' | inline_asset_content }}
          <span class="visually-hidden">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      <div class="yw-nav__icons">
        {%- if shop.customer_accounts_enabled -%}
          <a
            href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
            class="yw-nav__icon yw-icon--account"
            rel="nofollow"
          >
            <span class="svg-wrapper">{{ 'login--icon.svg' | inline_asset_content }}</span>
            <span class="visually-hidden">{{ 'customer.account_fallback' | t }}</span>
          </a>
        {%- endif -%}
        <a
          href="{{ routes.cart_url }}"
          class="yw-nav__icon yw-icon--cart link focus-inset"
          id="cart-icon-bubble"
        >
          {% if cart == empty %}
            <span class="svg-wrapper">{{ 'cart--icon.svg' | inline_asset_content }}</span>
            <span aria-hidden="true" class="cart-count-bubble">{{ cart.item_count }}</span>
          {% else %}
            <span class="svg-wrapper">{{ 'cart--icon.svg' | inline_asset_content }}</span>
            <span aria-hidden="true" class="cart-count-bubble">{{ cart.item_count }}</span>
          {% endif %}
          <span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>
          {%- if cart != empty -%}
            <div class="cart-count-bubble">
              {%- if cart.item_count < 100 -%}
                <span aria-hidden="true">{{ cart.item_count }}</span>
              {%- endif -%}
              <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
            </div>
          {%- endif -%}
        </a>
      </div>
    </div>

    <div class="yw-mobile-menu__body">
      {%- comment -%} The mobile menu is built from Mobile:* blocks (customizer). {%- endcomment -%}
      {%- liquid
        assign mobile_block_count = 0
        for block in section.blocks
          case block.type
            when 'mobile_link', 'mobile_cards', 'mobile_linklist', 'mobile_banner'
              assign mobile_block_count = mobile_block_count | plus: 1
          endcase
        endfor
      -%}

      {%- if mobile_block_count > 0 -%}
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'mobile_link' -%}
              <a
                class="yw-mm-link yw-mm-link--{{ block.settings.text | handleize }} {% if block.settings.image != blank %} yw-mm-link--img{% endif %}"
                href="{{ block.settings.link | default: '#' }}"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.image != blank -%}
                  {%- assign ml_alt = block.settings.text | escape -%}
                  {{
                    block.settings.image
                    | image_url: width: 160
                    | image_tag: class: 'yw-mm-link__img', alt: ml_alt, widths: '80, 120, 160', loading: 'lazy'
                  }}
                {%- endif -%}
                <span class="yw-mm-link__text">{{ block.settings.text }}</span>
                <svg width="20" height="10" viewBox="0 0 20 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12.5432 10C12.9023 9.17355 13.2751 8.44353 13.6617 7.80992C14.0484 7.14876 14.435 6.58402 14.8217 6.1157H0V3.8843H14.8217C14.435 3.38843 14.0484 2.82369 13.6617 2.19008C13.2751 1.52893 12.9023 0.798898 12.5432 0H14.4903C16.2302 2.01102 18.0668 3.49862 20 4.46281V5.53719C18.0668 6.47383 16.2302 7.96143 14.4903 10H12.5432Z" fill="black"/>
                </svg>
              </a>

            {%- when 'mobile_cards' -%}
              <div class="yw-mm-cards-block" {{ block.shopify_attributes }}>
                {%- if block.settings.text != blank -%}
                  <a class="yw-mm-cards__head" href="{{ block.settings.link | default: '#' }}">
                    {{- block.settings.text -}}
                    <svg width="20" height="10" viewBox="0 0 20 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12.5432 10C12.9023 9.17355 13.2751 8.44353 13.6617 7.80992C14.0484 7.14876 14.435 6.58402 14.8217 6.1157H0V3.8843H14.8217C14.435 3.38843 14.0484 2.82369 13.6617 2.19008C13.2751 1.52893 12.9023 0.798898 12.5432 0H14.4903C16.2302 2.01102 18.0668 3.49862 20 4.46281V5.53719C18.0668 6.47383 16.2302 7.96143 14.4903 10H12.5432Z" fill="black"/>
                    </svg>
                  </a>
                {%- endif -%}
                <div class="yw-mm-cards">
                  {%- for i in (1..3) -%}
                    {%- assign ik = 'card_' | append: i | append: '_image' -%}
                    {%- assign tk = 'card_' | append: i | append: '_title' -%}
                    {%- assign ck = 'card_' | append: i | append: '_caption' -%}
                    {%- assign lk = 'card_' | append: i | append: '_link' -%}
                    {%- assign c_img = block.settings[ik] -%}
                    {%- assign c_title = block.settings[tk] -%}
                    {%- assign c_caption = block.settings[ck] -%}
                    {%- assign c_link = block.settings[lk] -%}
                    {%- if c_title != blank or c_img != blank -%}
                      <a class="yw-mm-card" href="{{ c_link | default: '#' }}">
                        <span class="yw-mm-card__media">
                          {%- if c_img != blank -%}
                            {%- assign c_alt = c_title | escape -%}
                            {{
                              c_img
                              | image_url: width: 300
                              | image_tag:
                                class: 'yw-mm-card__img',
                                alt: c_alt,
                                widths: '150, 220, 300',
                                loading: 'lazy'
                            }}
                          {%- endif -%}
                        </span>
                        {%- if c_title != blank -%}
                          <span class="yw-mm-card__title">{{ c_title }}</span>
                        {%- endif -%}
                        {%- if c_caption != blank -%}
                          <span class="yw-mm-card__caption">{{ c_caption }}</span>
                        {%- endif -%}
                      </a>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>

            {%- when 'mobile_linklist' -%}
              <div class="yw-mm-list" {{ block.shopify_attributes }}>
                {%- if block.settings.title != blank -%}
                  <p class="yw-mm-list__title">{{ block.settings.title }}</p>
                {%- endif -%}
                {%- if block.settings.menu != blank -%}
                  {%- for link in block.settings.menu.links -%}
                    <a class="yw-mm-link" href="{{ link.url }}">{{ link.title }}</a>
                  {%- endfor -%}
                {%- endif -%}
              </div>

            {%- when 'mobile_banner' -%}
              {%- if block.settings.image != blank -%}
                <a class="yw-mm-banner" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
                  {{
                    block.settings.image
                    | image_url: width: 800
                    | image_tag: class: 'yw-mm-banner__img', alt: '', widths: '344, 500, 800', loading: 'lazy'
                  }}
                </a>
              {%- endif -%}
          {%- endcase -%}
        {%- endfor -%}

      {%- else -%}
        {%- comment -%} Fallback: no Mobile:* blocks configured yet — show the nav. {%- endcomment -%}
        {%- if section.settings.cta_text != blank -%}
          <a
            class="yw-nav__cta yw-mobile-menu__cta"
            href="{{ section.settings.cta_link | default: routes.all_products_collection_url }}"
          >
            {{- section.settings.cta_text -}}
          </a>
        {%- endif -%}
        <div class="yw-mobile-menu__links">
          {%- if section.settings.membership_text != blank -%}
            <a class="yw-mobile-menu__link" href="{{ section.settings.membership_link | default: '#' }}">
              {{- section.settings.membership_text -}}
            </a>
          {%- endif -%}
          {%- if section.settings.menu != blank -%}
            {%- for link in section.settings.menu.links -%}
              <a class="yw-mobile-menu__link" href="{{ link.url }}">{{ link.title }}</a>
            {%- endfor -%}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</yw-header>

{%- if settings.cart_type == 'notification' -%}
  {%- render 'cart-notification', color_scheme: section.settings.color_scheme -%}
{%- endif -%}

{%- comment -%} Structured data {%- endcomment -%}
<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if settings.logo %}
      "logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},
    {% endif %}
    "sameAs": [
      {{ settings.social_twitter_link | json }},
      {{ settings.social_facebook_link | json }},
      {{ settings.social_pinterest_link | json }},
      {{ settings.social_instagram_link | json }},
      {{ settings.social_tiktok_link | json }},
      {{ settings.social_tumblr_link | json }},
      {{ settings.social_snapchat_link | json }},
      {{ settings.social_youtube_link | json }},
      {{ settings.social_vimeo_link | json }}
    ],
    "url": {{ request.origin | append: page.url | json }}
  }
</script>

{%- if request.page_type == 'index' -%}
  {% assign potential_action_target = request.origin | append: routes.search_url | append: '?q={search_term_string}' %}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ potential_action_target | json }},
        "query-input": "required name=search_term_string"
      },
      "url": {{ request.origin | append: page.url | json }}
    }
  </script>
{%- endif -%}

