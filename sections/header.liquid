96C20.4946 2.53395 20.0463 2.79994 19.8782 2.79994L19.8642 2.78594Z" fill="black"></path>
                </svg>
              </span>
              <span aria-hidden="true" class="cart-count-bubble">{{ cart.item_count }}</span>
            {% endif %}
            <span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>
            {%- if cart != empty -%}
              <div class="cart-count-bubble">
                {%- if cart.item_count < 100 -%}
                  <span aria-hidden="true">{{ cart.item_count }}</span>
                {%- endif -%}
                <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
              </div>
            {%- endif -%}
          </a>
        </div>
      </div>
    </nav>
  </div>

  {%- comment -%} ---------------- Mobile menu overlay ---------------- {%- endcomment -%}
  <div class="yw-mobile-menu" id="{{ mobile_id }}">
    {%- comment -%} ---------------- Announcement topbar ---------------- {%- endcomment -%}
    {%- if section.settings.show_announcement and section.settings.announcement_text != blank -%}
      <div class="yw-topbar" role="region" aria-label="{{ 'sections.header.announcement' | t }}">
        <div class="yw-topbar__inner">
          {%- if section.settings.announcement_link != blank -%}
            <a class="yw-topbar__link" href="{{ section.settings.announcement_link }}">
              {{- section.settings.announcement_text -}}
            </a>
          {%- else -%}
            <p class="yw-topbar__text">{{ section.settings.announcement_text }}</p>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
    <div class="yw-mobile-menu__bar">
      <button
        type="button"
        class="yw-mobile-menu__close"
        aria-label="{{ 'accessibility.close' | t | default: 'Close' }}"
      >
        <span class="svg-wrapper">{{ 'icon-close.svg' | inline_asset_content }}</span>
      </button>

      <a href="{{ routes.root_url }}" class="yw-nav__logo" aria-label="{{ shop.name | escape }}">
        {%- if settings.logo != blank -%}
          {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
          {{
            settings.logo
            | image_url: width: 300
            | image_tag: widths: '150, 220, 300', alt: logo_alt, loading: 'lazy'
          }}
        {%- else -%}
          {{ 'yumwoof-logo.svg' | inline_asset_content }}
          <span class="visually-hidden">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      <div class="yw-nav__icons">
        {%- if shop.customer_accounts_enabled -%}
          <a
            href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
            class="yw-nav__icon yw-icon--account"
            rel="nofollow"
          >
            <span class="svg-wrapper">
              <svg width="27" height="28" viewBox="0 0 27 28" fill="none" xmlns="http://www.w3.org/2000/svg">
