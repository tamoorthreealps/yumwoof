                              </svg>
                            </button>
                          </cart-remove-button>

                          <div
                            id="CartDrawer-LineItemError-{{ item.index | plus: 1 }}"
                            class="cart-item__error"
                            role="alert"
                          >
                            <small class="cart-item__error-text"></small>
                          </div>
                        </div>
                      </div>
                    </div>
                    {%- if has_plans -%}
                      <div class="cd-item__sub">
                        <div class="cd-item__divider" aria-hidden="true">
                          <svg
                            width="452"
                            height="1"
                            viewBox="0 0 452 1"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                          >
