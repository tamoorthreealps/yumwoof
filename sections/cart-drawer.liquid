{{ 'css--cart-drawer.css' | asset_url | stylesheet_tag }}
<script src="{{ 'custom-cart-subscription.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  #shopify-section-{{ section.id }} .cd {
    --cd-drawer-bg: {{ section.settings.drawer_bg }};
    --cd-header-bg: {{ section.settings.header_bg }};
    --cd-header-text: {{ section.settings.header_text }};
    --cd-accent: {{ section.settings.accent_color }};
    --cd-cta-bg: {{ section.settings.cta_bg }};
  }
{%- endstyle -%}

{%- liquid
  assign cart_cents = cart.total_price

  # --- Active market currency: thresholds are entered per market (US/EU/UK/CH). ---
  # Pick the field suffix from the cart's currency, falling back to USD.
  assign cart_currency = cart.currency.iso_code | default: shop.currency
  assign cur_suffix = 'usd'
  if cart_currency == 'EUR'
    assign cur_suffix = 'eur'
  elsif cart_currency == 'GBP'
    assign cur_suffix = 'gbp'
  elsif cart_currency == 'CHF'
    assign cur_suffix = 'chf'
  endif

  # --- Yum Club membership: logged-in customers with the member tag get a flat
  #     member discount scheme instead of the spend-based tiered thresholds. ---
  assign member_tag = section.settings.member_tag | default: 'Yum Club Membership!'
  assign is_member = false
  if customer and customer.tags contains member_tag
    assign is_member = true
  endif
  assign member_percent = section.settings.member_percent | default: 25
  assign show_member_scheme = false
  if section.settings.member_enable and is_member
    assign show_member_scheme = true
  endif

  # Reward thresholds (up to 4) live in section settings so they survive AJAX re-renders.
  assign threshold_count = 0
  assign max_threshold_cents = 0
  assign next_index = 0
  assign all_unlocked = true
  for i in (1..4)
    assign ek = 'threshold_' | append: i | append: '_enable'
    assign ak = 'threshold_' | append: i | append: '_amount_' | append: cur_suffix
    assign enabled = section.settings[ek]
    assign amt = section.settings[ak]
    if amt == blank
      assign ak_usd = 'threshold_' | append: i | append: '_amount_usd'
      assign amt = section.settings[ak_usd]
    endif
    if enabled and amt > 0
      assign threshold_count = threshold_count | plus: 1
      assign b_cents = amt | times: 100
      if b_cents > max_threshold_cents
        assign max_threshold_cents = b_cents
      endif
      if cart_cents < b_cents
        assign all_unlocked = false
        if next_index == 0
          assign next_index = i
        endif
      endif
    endif
  endfor

  assign extra_percent = 0
  if show_member_scheme
    assign extra_percent = member_percent
  elsif next_index > 0
    assign pk = 'threshold_' | append: next_index | append: '_percent'
    assign extra_percent = section.settings[pk]
  endif

  # Reward message (build the {remaining} replace here, never inside a {{ }} output tag)
  assign reward_message = ''
  if all_unlocked
    assign reward_message = section.settings.unlocked_message
  elsif next_index > 0
    assign mk = 'threshold_' | append: next_index | append: '_message'
    assign nak = 'threshold_' | append: next_index | append: '_amount_' | append: cur_suffix
    assign next_amt = section.settings[nak]
    if next_amt == blank
      assign nak_usd = 'threshold_' | append: next_index | append: '_amount_usd'
      assign next_amt = section.settings[nak_usd]
    endif
    assign next_cents = next_amt | times: 100
    assign remaining_money = next_cents | minus: cart_cents | money
    assign remaining_html = '<span class="cd-rewards__amount">' | append: remaining_money | append: '</span>'
    assign placeholder = '{remaining}'
    assign reward_message = section.settings[mk] | replace: placeholder, remaining_html
  endif

  # Member scheme message ({percent} is replaced here, never inside a {{ }} tag)
  assign member_message = ''
  if show_member_scheme
    assign member_message = section.settings.member_message | default: 'Yum Club member — {percent}% off applied'
    assign member_message = member_message | replace: '{percent}', member_percent
  endif

  # Total savings against the best available compare-at price
  assign total_savings = 0
  for item in cart.items
    assign compare_unit = item.variant.compare_at_price
    if item.selling_plan_allocation != null and item.selling_plan_allocation.compare_at_price > item.final_price
      assign compare_unit = item.selling_plan_allocation.compare_at_price
    endif
    if compare_unit > item.final_price
      assign item_saving = compare_unit | minus: item.final_price | times: item.quantity
      assign total_savings = total_savings | plus: item_saving
    endif
  endfor

  assign rec_intent = section.settings.recommend_intent | default: 'related'
-%}

<cart-drawer class="drawer{% if cart == empty %} is-empty{% endif %}">
  <div id="CartDrawer" class="cart-drawer cd">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>

    <div
      class="drawer__inner cd__inner{% if cart == empty %} is-empty{% endif %}"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'sections.cart.title' | t }}"
      tabindex="-1"
    >
      <span id="CartDrawer-SectionId" data-section-id="{{ section.id }}" hidden></span>

      {%- comment -%} ===== HEADER ===== {%- endcomment -%}
      <div class="cd__header">
        <h2 class="cd__title">
          {{ section.settings.title }}
          {%- if cart != empty -%}
            <span class="cd__count">[{{ cart.item_count }} {{ cart.item_count | pluralize: 'ITEM', 'ITEMS' }}]</span>
          {%- endif -%}
        </h2>
        <button
          class="drawer__close cd__close"
          type="button"
          onclick="this.closest('cart-drawer').close()"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          <svg width="14" height="14" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M1 1l10 10M11 1L1 11" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
        </button>
      </div>

      {%- if cart == empty -%}
        {%- comment -%} ===== EMPTY STATE ===== {%- endcomment -%}
        <div class="drawer__inner-empty cd-empty">
          <span class="cd-empty__icon" aria-hidden="true">
            <svg width="44" height="52" viewBox="0 0 44 52" fill="none"><path d="M8 16h28l-2 32a4 4 0 0 1-4 4H14a4 4 0 0 1-4-4z" stroke="currentColor" stroke-width="2"/><path d="M8 16l4-14h20l4 14" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
            <span class="cd-empty__count">0</span>
          </span>
          <h3 class="cd-empty__title">{{ section.settings.empty_heading }}</h3>
          {%- if section.settings.empty_text != blank -%}
            <p class="cd-empty__text">{{ section.settings.empty_text }}</p>
          {%- endif -%}

          {%- if section.settings.empty_collection != blank -%}
            {%- assign empty_coll = section.settings.empty_collection -%}
            <div class="cd-shop" data-cd-carousel>
              <div class="cd-shop__head">
                <p class="cd-shop__label">{{ section.settings.empty_collection_title }}</p>
                <div class="cd-carousel__nav">
                  <button type="button" class="cd-carousel__arrow" data-cd-prev aria-label="Previous">&larr;</button>
                  <button type="button" class="cd-carousel__arrow" data-cd-next aria-label="Next">&rarr;</button>
                </div>
              </div>
              <div class="cd-shop__track" data-cd-track>
                {%- for product in empty_coll.products limit: 8 -%}
                  {% render 'cart-drawer-product-card', product: product, style: 'empty' %}
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}

          <a href="{{ section.settings.empty_button_link | default: routes.all_products_collection_url }}" class="cd-empty__shop-all">
            {{ section.settings.empty_button_label }}
          </a>
        </div>
      {%- else -%}

        {%- comment -%} ===== REWARDS: member scheme OR spend-based tiers ===== {%- endcomment -%}
        {%- if show_member_scheme -%}
          <div class="cd-rewards cd-rewards--member">
            <p class="cd-rewards__msg">{{ member_message }}</p>
          </div>
        {%- elsif threshold_count > 0 -%}
          <div class="cd-rewards">
            <p class="cd-rewards__msg">{{ reward_message }}</p>

            <div class="cd-rewards__track">
              {%- assign prev_cents = 0 -%}
              {%- for i in (1..4) -%}
                {%- assign ek = 'threshold_' | append: i | append: '_enable' -%}
                {%- assign ak = 'threshold_' | append: i | append: '_amount_' | append: cur_suffix -%}
                {%- assign lk = 'threshold_' | append: i | append: '_label' -%}
                {%- assign enabled = section.settings[ek] -%}
                {%- assign amt = section.settings[ak] -%}
                {%- if amt == blank -%}{%- assign ak_usd = 'threshold_' | append: i | append: '_amount_usd' -%}{%- assign amt = section.settings[ak_usd] -%}{%- endif -%}
                {%- if enabled and amt > 0 -%}
                  {%- assign b_cents = amt | times: 100 -%}
                  {%- assign reached = false -%}
                  {%- if cart_cents >= b_cents -%}{%- assign reached = true -%}{%- endif -%}
                  {%- assign seg_pct = 0 -%}
                  {%- if reached -%}
                    {%- assign seg_pct = 100 -%}
                  {%- elsif cart_cents > prev_cents -%}
                    {%- assign span = b_cents | minus: prev_cents -%}
                    {%- assign done = cart_cents | minus: prev_cents -%}
                    {%- if span > 0 -%}{%- assign seg_pct = done | times: 100 | divided_by: span -%}{%- endif -%}
                  {%- endif -%}
                  <div class="cd-reward{% if reached %} is-reached{% endif %}">
                    <span class="cd-reward__bar"><span class="cd-reward__fill" style="width: {{ seg_pct }}%"></span></span>
                    <span class="cd-reward__label">{% if reached %}<span class="cd-reward__check" aria-hidden="true">&#10003;</span> {% endif %}{{ section.settings[lk] }}</span>
                    <span class="cd-reward__amount">{{ amt | times: 100 | money_without_trailing_zeros }}</span>
                  </div>
                  {%- assign prev_cents = b_cents -%}
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} ===== BANNER OFFER ===== {%- endcomment -%}
        {%- if section.settings.banner_enable -%}
          {%- capture banner_inner -%}
            {%- if section.settings.banner_image_desktop != blank -%}
              {%- assign bd_alt = section.settings.banner_image_desktop.alt | default: '' -%}
              {{ section.settings.banner_image_desktop | image_url: width: 1000 | image_tag: class: 'cd-banner__img cd-banner__img--desktop', widths: '500, 750, 1000', alt: bd_alt, loading: 'lazy' }}
            {%- endif -%}
            {%- if section.settings.banner_image_mobile != blank -%}
              {%- assign bm_alt = section.settings.banner_image_mobile.alt | default: '' -%}
              {{ section.settings.banner_image_mobile | image_url: width: 800 | image_tag: class: 'cd-banner__img cd-banner__img--mobile', widths: '400, 600, 800', alt: bm_alt, loading: 'lazy' }}
            {%- endif -%}
          {%- endcapture -%}
          {%- if banner_inner != blank -%}
            <div class="cd-banner">
              {%- if section.settings.banner_link != blank -%}
                <a href="{{ section.settings.banner_link }}" class="cd-banner__link">{{ banner_inner }}</a>
              {%- else -%}
                {{ banner_inner }}
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endif -%}

        {%- comment -%} ===== CART ITEMS ===== {%- endcomment -%}
        <cart-drawer-items class="cd-items-wrap">
          <form action="{{ routes.cart_url }}" id="CartDrawer-Form" class="cart__contents cart-drawer__form" method="post">
            <div id="CartDrawer-CartItems" class="js-contents cd-items">
              {%- for item in cart.items -%}
                {%- liquid
                  assign is_sub = false
                  if item.selling_plan_allocation != null
                    assign is_sub = true
                  endif

                  assign has_plans = false
                  assign default_plan_id = null
                  assign default_plan_percent = 0
                  assign plan_count = 0
                  for group in item.product.selling_plan_groups
                    for plan in group.selling_plans
                      assign has_plans = true
                      assign plan_count = plan_count | plus: 1
                      if default_plan_id == null
                        assign default_plan_id = plan.id
                        assign first_adj = plan.price_adjustments.first
                        if first_adj.value_type == 'percentage'
                          assign default_plan_percent = first_adj.value
                        endif
                      endif
                    endfor
                  endfor

                  assign sub_percent = default_plan_percent
                  if is_sub
                    assign cur_adj = item.selling_plan_allocation.selling_plan.price_adjustments.first
                    if cur_adj.value_type == 'percentage'
                      assign sub_percent = cur_adj.value
                    endif
                  endif

                  assign item_compare_unit = item.variant.compare_at_price
                  if item.selling_plan_allocation != null and item.selling_plan_allocation.compare_at_price > item.final_price
                    assign item_compare_unit = item.selling_plan_allocation.compare_at_price
                  endif
                  assign item_compare_line = item_compare_unit | times: item.quantity
                  assign discount_pct = 0
                  if item_compare_unit > item.final_price
                    assign saved_unit = item_compare_unit | minus: item.final_price
                    assign discount_pct = saved_unit | times: 100 | divided_by: item_compare_unit
                  endif
                -%}

                <div id="CartDrawer-Item-{{ item.index | plus: 1 }}" class="cd-item" role="row">
                  <div class="cd-item__media">
                    {%- if item.image -%}
                      {%- assign cd_img_alt = item.image.alt | escape -%}
                      <a href="{{ item.url }}" tabindex="-1" aria-hidden="true">
                        {{ item.image | image_url: width: 240 | image_tag: class: 'cd-item__img', widths: '120, 180, 240', alt: cd_img_alt, loading: 'lazy' }}
                      </a>
                    {%- endif -%}
                  </div>

                  <div class="cd-item__main">
                    <div class="cd-item__top">
                      <div class="cd-item__titles">
                        <a href="{{ item.url }}" class="cd-item__name">{{ item.product.title | escape }}</a>
                        {%- unless item.product.has_only_default_variant -%}
                          <p class="cd-item__recipe">{{ item.variant.title | escape }}</p>
                        {%- endunless -%}
                        <p class="cd-item__note">
                          {%- if is_sub -%}{{ item.selling_plan_allocation.selling_plan.name }}{%- else -%}One-Time{%- endif -%}
                        </p>
                      </div>
                      <div class="cd-item__price">
                        {%- if item_compare_unit > item.final_price -%}
                          <span class="cd-item__price-row">
                            <s class="cd-item__compare">{{ item_compare_line | money }}</s>
                            <span class="cd-item__final">{{ item.final_line_price | money }}</span>
                          </span>
                          <span class="cd-item__off">({{ discount_pct }}% Off)</span>
                        {%- else -%}
                          <span class="cd-item__final">{{ item.final_line_price | money }}</span>
                        {%- endif -%}
                      </div>
                    </div>

                    <div class="cd-item__bottom">
                      <quantity-input class="cd-qty">
                        <button class="cd-qty__btn quantity__button" name="minus" type="button" aria-label="{{ 'products.product.quantity.decrease' | t: product: item.product.title | escape }}">&minus;</button>
                        <input
                          class="cd-qty__input"
                          type="number"
                          name="updates[]"
                          value="{{ item.quantity }}"
                          data-quantity-variant-id="{{ item.variant.id }}"
                          data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                          min="0"
                          data-min="{{ item.variant.quantity_rule.min | default: 1 }}"
                          {% if item.variant.quantity_rule.max != null %}max="{{ item.variant.quantity_rule.max }}"{% endif %}
                          step="{{ item.variant.quantity_rule.increment | default: 1 }}"
                          data-index="{{ item.index | plus: 1 }}"
                          id="Drawer-quantity-{{ item.index | plus: 1 }}"
                          aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                        >
                        <button class="cd-qty__btn quantity__button" name="plus" type="button" aria-label="{{ 'products.product.quantity.increase' | t: product: item.product.title | escape }}">+</button>
                      </quantity-input>

                      <cart-remove-button id="CartDrawer-Remove-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}">
                        <button type="button" class="cd-item__remove" aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}">
                          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M2.5 4.5h11M6 4.5V3a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v1.5M12.5 4.5l-.6 8.5a1.5 1.5 0 0 1-1.5 1.4H5.6a1.5 1.5 0 0 1-1.5-1.4L3.5 4.5" stroke="currentColor" stroke-width="1.1"/></svg>
                        </button>
                      </cart-remove-button>

                      <div id="CartDrawer-LineItemError-{{ item.index | plus: 1 }}" class="cart-item__error" role="alert"><small class="cart-item__error-text"></small></div>
                    </div>

                    {%- if has_plans -%}
                      <div class="cd-item__sub">
                        <span class="cd-item__divider" aria-hidden="true"></span>
                        <div class="cd-item__sub-row">
                          <cart-subscription-toggle
                            class="cd-toggle{% if is_sub %} is-on{% endif %}"
                            data-line-index="{{ item.index | plus: 1 }}"
                            data-variant-id="{{ item.variant.id }}"
                            data-quantity="{{ item.quantity }}"
                            data-plan-id="{{ default_plan_id }}"
                          >
                            <button type="button" class="cd-toggle__switch" role="switch" aria-checked="{% if is_sub %}true{% else %}false{% endif %}">
                              <span class="cd-toggle__knob"></span>
                            </button>
                            <span class="cd-toggle__label">
                              {%- if is_sub -%}Auto-ship &middot; saving {{ sub_percent }}%{%- else -%}Subscribe &amp; save {{ default_plan_percent }}%{%- endif -%}
                            </span>
                          </cart-subscription-toggle>

                          {%- if is_sub -%}
                            <cart-subscription-selector
                              class="cd-freq"
                              data-line-index="{{ item.index | plus: 1 }}"
                              data-variant-id="{{ item.variant.id }}"
                              data-quantity="{{ item.quantity }}"
                            >
                              <select class="cd-freq__select" aria-label="Delivery frequency">
                                {%- for group in item.product.selling_plan_groups -%}
                                  {%- for plan in group.selling_plans -%}
                                    <option value="{{ plan.id }}" {% if plan.id == item.selling_plan_allocation.selling_plan.id %}selected{% endif %}>{{ plan.name }}</option>
                                  {%- endfor -%}
                                {%- endfor -%}
                              </select>
                            </cart-subscription-selector>
                          {%- endif -%}
                        </div>
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              {%- endfor -%}

              <p id="CartDrawer-LiveRegionText" class="visually-hidden" role="status"></p>
              <p id="CartDrawer-LineItemStatus" class="visually-hidden" aria-hidden="true" role="status">{{ 'accessibility.loading' | t }}</p>
            </div>
            <div id="CartDrawer-CartErrors" role="alert"></div>
          </form>
        </cart-drawer-items>

        {%- comment -%} ===== ADD MORE, SAVE MORE ===== {%- endcomment -%}
        {%- assign last_item = cart.items.last -%}
        <cart-recommendations
          class="cd-recommend"
          data-url="{{ routes.product_recommendations_url }}?section_id=cart-recommendations&intent={{ rec_intent }}&limit=6"
          data-product-id="{{ last_item.product.id }}"
        >
          <div class="cd-recommend__head">
            <p class="cd-recommend__title">
              {{ section.settings.recommend_title }}
              {%- if extra_percent > 0 -%} <span class="cd-recommend__extra">(EXTRA {{ extra_percent }}%)</span>{%- endif -%}
            </p>
            <div class="cd-carousel__nav">
              <button type="button" class="cd-carousel__arrow" data-cd-prev aria-label="Previous">&larr;</button>
              <button type="button" class="cd-carousel__arrow" data-cd-next aria-label="Next">&rarr;</button>
            </div>
          </div>
          <div class="cd-recommend__track" data-cd-track></div>
        </cart-recommendations>

        {%- comment -%} ===== FOOTER ===== {%- endcomment -%}
        <div class="drawer__footer cd-footer">
          <div class="cart-drawer__footer">
            <div class="cd-totals">
              <div class="cd-totals__row cd-totals__row--total">
                <span class="cd-totals__label">Subtotal</span>
                <span class="cd-totals__value">
                  {%- if total_savings > 0 -%}<s class="cd-totals__was">{{ cart.original_total_price | money }}</s> {% endif -%}
                  {{ cart.total_price | money }}
                </span>
              </div>
              {%- if total_savings > 0 -%}
                <div class="cd-totals__row cd-totals__row--savings">
                  <span>Total Savings!</span>
                  <span>{{ total_savings | money }}</span>
                </div>
              {%- endif -%}
            </div>

            <button type="submit" id="CartDrawer-Checkout" class="cd-checkout" name="checkout" form="CartDrawer-Form">
              {{ section.settings.checkout_label }}
            </button>

            {%- if section.settings.guarantee_text != blank -%}
              <p class="cd-guarantee">{{ section.settings.guarantee_text }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</cart-drawer>

{% schema %}
{
  "name": "Cart drawer",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "IN YOUR BAG" },
    { "type": "text", "id": "checkout_label", "label": "Checkout button label", "default": "PROCEED TO CHECKOUT" },
    { "type": "text", "id": "guarantee_text", "label": "Guarantee note", "default": "21-day money-back guarantee" },
    { "type": "header", "content": "Add more, save more" },
    { "type": "text", "id": "recommend_title", "label": "Title", "default": "Add more, save more" },
    {
      "type": "select",
      "id": "recommend_intent",
      "label": "Recommendation source",
      "options": [
        { "value": "related", "label": "Related products" },
        { "value": "complementary", "label": "Complementary products" }
      ],
      "default": "related",
      "info": "Set the products in the Shopify Search & Discovery app."
    },
    { "type": "header", "content": "Yum Club membership (members)" },
    { "type": "paragraph", "content": "Logged-in customers with the member tag see a flat member discount instead of the spend-based tiers." },
    { "type": "checkbox", "id": "member_enable", "label": "Enable member scheme", "default": true },
    { "type": "text", "id": "member_tag", "label": "Member customer tag", "default": "Yum Club Membership!" },
    { "type": "number", "id": "member_percent", "label": "Member discount %", "default": 25 },
    { "type": "text", "id": "member_message", "label": "Member message", "info": "Use {percent} for the discount value.", "default": "Yum Club member — {percent}% off applied" },
    { "type": "header", "content": "Reward thresholds (non-members)" },
    { "type": "paragraph", "content": "Enable up to 4 spend tiers. Amounts are entered per market (US/EU/UK/CH) and the cart uses the active currency, falling back to US. Use {remaining} in a message for the amount left." },
    { "type": "text", "id": "unlocked_message", "label": "All-tiers-unlocked message", "default": "You've unlocked every reward! 🎉" },
    { "type": "header", "content": "Threshold 1" },
    { "type": "checkbox", "id": "threshold_1_enable", "label": "Enable", "default": true },
    { "type": "text", "id": "threshold_1_label", "label": "Milestone label", "default": "Free Shipping" },
    { "type": "text", "id": "threshold_1_message", "label": "Progress message", "default": "You're {remaining} away from Free Shipping" },
