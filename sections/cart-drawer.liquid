{{ 'css--cart-drawer.css' | asset_url | stylesheet_tag }}
<script src="{{ 'custom-cart-subscription.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  #shopify-section-{{ section.id }} .cd {
    --cd-drawer-bg: {{ section.settings.drawer_bg }};
    --cd-header-bg: {{ section.settings.header_bg }};
    --cd-header-text: {{ section.settings.header_text }};
    --cd-accent: {{ section.settings.accent_color }};
    --cd-cta-bg: {{ section.settings.cta_bg }};
  }
{%- endstyle -%}

{%- liquid
  assign cart_cents = cart.total_price

  # --- Active market currency: thresholds are entered per market (US/EU/UK/CH). ---
  # Pick the field suffix from the cart's currency, falling back to USD.
  assign cart_currency = cart.currency.iso_code | default: shop.currency
  assign cur_suffix = 'usd'
  if cart_currency == 'EUR'
    assign cur_suffix = 'eur'
  elsif cart_currency == 'GBP'
    assign cur_suffix = 'gbp'
  elsif cart_currency == 'CHF'
    assign cur_suffix = 'chf'
  endif

  # --- Yum Club membership: logged-in customers with the member tag get a flat
  #     member discount scheme instead of the spend-based tiered thresholds. ---
  assign member_tag = section.settings.member_tag | default: 'Yum Club Membership!'
  assign is_member = false
  if customer and customer.tags contains member_tag
    assign is_member = true
  endif
  assign member_percent = section.settings.member_percent | default: 25
  assign show_member_scheme = false
  if section.settings.member_enable and is_member
    assign show_member_scheme = true
  endif

  # Reward thresholds (up to 4) live in section settings so they survive AJAX re-renders.
  assign threshold_count = 0
  assign max_threshold_cents = 0
  assign next_index = 0
  assign all_unlocked = true
  for i in (1..4)
    assign ek = 'threshold_' | append: i | append: '_enable'
    assign ak = 'threshold_' | append: i | append: '_amount_' | append: cur_suffix
    assign enabled = section.settings[ek]
    assign amt = section.settings[ak]
    if amt == blank
      assign ak_usd = 'threshold_' | append: i | append: '_amount_usd'
      assign amt = section.settings[ak_usd]
    endif
    if enabled and amt > 0
      assign threshold_count = threshold_count | plus: 1
      assign b_cents = amt | times: 100
      if b_cents > max_threshold_cents
        assign max_threshold_cents = b_cents
      endif
      if cart_cents < b_cents
        assign all_unlocked = false
        if next_index == 0
          assign next_index = i
        endif
      endif
    endif
  endfor

  assign extra_percent = 0
  if show_member_scheme
    assign extra_percent = member_percent
  elsif next_index > 0
    assign pk = 'threshold_' | append: next_index | append: '_percent'
    assign extra_percent = section.settings[pk]
  endif

  # Reward message (build the {remaining} replace here, never inside a {{ }} output tag)
  assign reward_message = ''
  if all_unlocked
    assign reward_message = section.settings.unlocked_message
  elsif next_index > 0
    assign mk = 'threshold_' | append: next_index | append: '_message'
    assign nak = 'threshold_' | append: next_index | append: '_amount_' | append: cur_suffix
    assign next_amt = section.settings[nak]
    if next_amt == blank
      assign nak_usd = 'threshold_' | append: next_index | append: '_amount_usd'
      assign next_amt = section.settings[nak_usd]
    endif
    assign next_cents = next_amt | times: 100
    assign remaining_money = next_cents | minus: cart_cents | money
    assign remaining_html = '<span class="cd-rewards__amount">' | append: remaining_money | append: '</span>'
    assign placeholder = '{remaining}'
    assign reward_message = section.settings[mk] | replace: placeholder, remaining_html
  endif

  # Member scheme message ({percent} is replaced here, never inside a {{ }} tag)
  assign member_message = ''
  if show_member_scheme
    assign member_message = section.settings.member_message | default: 'Yum Club member — {percent}% off applied'
    assign member_message = member_message | replace: '{percent}', member_percent
  endif

  # Total savings against the best available compare-at price
  assign total_savings = 0
  for item in cart.items
    assign compare_unit = item.variant.compare_at_price
    if item.selling_plan_allocation != null and item.selling_plan_allocation.compare_at_price > item.final_price
      assign compare_unit = item.selling_plan_allocation.compare_at_price
    endif
    if compare_unit > item.final_price
      assign item_saving = compare_unit | minus: item.final_price | times: item.quantity
      assign total_savings = total_savings | plus: item_saving
    endif
  endfor

  assign rec_intent = section.settings.recommend_intent | default: 'related'
-%}

<cart-drawer class="drawer{% if cart == empty %} is-empty{% endif %}">
  <div id="CartDrawer" class="cart-drawer cd">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>
    <div class="drawer__inner__main">
      <div
        class="drawer__inner cd__inner{% if cart == empty %} is-empty{% endif %}"
        role="dialog"
        aria-modal="true"
        aria-label="{{ 'sections.cart.title' | t }}"
        tabindex="-1"
      >
        <span id="CartDrawer-SectionId" data-section-id="{{ section.id }}" hidden></span>

        {%- comment -%} ===== HEADER ===== {%- endcomment -%}
        <div class="cd__header">
          <h2 class="cd__title">
            {{ section.settings.title }}
            {%- if cart != empty -%}
              <span class="cd__count"
                >[{{ cart.item_count }}
                {{ cart.item_count | pluralize: 'ITEM', 'ITEMS' }}]</span
              >
            {%- endif -%}
          </h2>
          <button
            class="drawer__close cd__close"
            type="button"
            onclick="this.closest('cart-drawer').close()"
            aria-label="{{ 'accessibility.close' | t }}"
          >
            <svg width="9" height="11" viewBox="0 0 9 11" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M4.37355 3.85209L4.82355 3.18609L5.66955 1.81809L6.67755 0.324093C6.80355 0.126093 7.01955 0.0180935 7.25355 0.0180935H8.20755C8.36955 9.36985e-05 8.51355 0.0900936 8.60355 0.216093C8.62155 0.270093 8.62155 0.324093 8.60355 0.360093L8.51355 0.558093L7.10955 2.70009L5.77755 4.77009L5.65155 5.00409C5.32755 5.45409 5.32755 5.45409 5.59755 5.88609L6.87555 7.86609L7.99155 9.66609L8.36955 10.1521C8.49555 10.2601 8.53155 10.4401 8.47755 10.5841C8.40555 10.7461 8.26155 10.7281 8.11755 10.7281H7.00155C6.80355 10.7461 6.62355 10.6381 6.51555 10.4761L5.34555 8.60409L4.48155 7.34409C4.42755 7.25409 4.30155 7.23609 4.22955 7.30809L3.90555 7.66809V7.68609C3.36555 8.51409 2.84355 9.36009 2.32155 10.2061C2.15955 10.5661 1.78155 10.7821 1.38555 10.7461C1.09755 10.7101 0.791547 10.7461 0.503547 10.7281C0.143547 10.7101 -0.00045301 10.4581 0.251547 10.2241C0.557547 9.84609 0.845547 9.43209 1.07955 9.01809C1.52955 8.33409 1.94355 7.65009 2.37555 6.96609L3.05955 5.90409C3.32955 5.45409 3.31155 5.45409 3.02355 5.02209C2.55555 4.32009 2.12355 3.60009 1.67355 2.89809C1.40355 2.46609 1.09755 2.07009 0.827547 1.63809L0.053547 0.414094C0.0355469 0.360093 0.0355469 0.306093 0.053547 0.252094C0.125547 0.0900936 0.233547 0.0360932 0.377547 0.0360932C0.755547 0.0360932 1.11555 0.0180935 1.49355 0.0360932C1.69155 0.054093 1.87155 0.162094 1.96155 0.324093C2.33955 0.918094 2.68155 1.53009 3.11355 2.08809C3.54555 2.64609 3.81555 3.25809 4.22955 3.79809C4.24755 3.81609 4.28355 3.81609 4.37355 3.85209Z" fill="#FFF9EF"/>
            </svg>
          </button>
        </div>

        {%- if cart == empty -%}
          {%- comment -%} ===== EMPTY STATE ===== {%- endcomment -%}
          <div class="drawer__inner-empty cd-empty">
            <span class="cd-empty__icon" aria-hidden="true">
              <svg width="46" height="56" viewBox="0 0 46 56" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M45.1918 47.0111C45.0797 45.7791 44.9677 44.6311 44.9677 42.2232C44.9677 37.2953 45.0237 37.2953 45.0237 32.3674C45.0237 29.8754 45.0237 28.6714 45.0237 27.4115C45.0237 26.1515 45.0237 24.9475 44.9397 22.5396V22.2596C44.9397 21.7276 44.9677 21.4476 45.0237 21.1116C45.0517 20.8036 45.1078 20.4396 45.1078 19.9356C45.1078 19.6276 45.1078 19.2916 45.0517 18.8716C44.7435 15.9597 44.4634 14.4757 44.2112 13.0477C43.9591 11.6198 43.7069 10.2478 43.4828 7.36385C43.4547 6.99986 43.4547 6.74787 43.4547 6.52387C43.4547 6.07588 43.4828 5.82388 43.5388 5.43189C43.5948 5.0399 43.6509 4.53591 43.6509 3.80792V3.55593C43.5108 1.62397 41.8858 0.139997 39.9246 0H39.7004C38.916 0 38.4397 0.0839983 38.0474 0.139997C37.6552 0.195996 37.375 0.251995 36.6466 0.251995H36.3664C32.1078 0.251995 32.0237 0.139997 27.5129 0.139997H27.4849C22.9461 0.139997 22.9181 0.167997 18.3793 0.167997C13.8405 0.167997 13.8405 0.0279994 9.24569 0.0279994H9.18966C8.26509 0.0279994 7.76078 0.0839983 7.3125 0.139997C6.86422 0.195996 6.5 0.223996 5.63147 0.251995C4.59483 0.279994 3.64224 0.643987 2.88578 1.25997C2.12931 1.87596 1.59698 2.79994 1.59698 3.86392C1.59698 5.34789 1.73707 5.76789 1.70905 6.46787C1.70905 6.74787 1.70905 7.08386 1.65302 7.61585C1.14871 13.5237 1.37284 13.4957 0.700431 19.3196C0.616379 20.3276 0.112069 21.4756 0.0840516 22.9315C0.0840516 27.8034 0.140086 27.8034 0.140086 32.6194V32.7034C0.140086 37.3793 0 37.4633 0 42.2232V42.3072C0 44.7711 0.140086 46.0311 0.252155 47.2631C0.364224 48.467 0.504311 49.615 0.504311 51.995C0.504311 53.0589 0.924569 54.0389 1.59698 54.7669C2.2694 55.5229 3.27802 56.0269 4.39871 55.9989C10.5345 55.9989 10.5345 55.7749 16.6142 55.7749C22.75 55.7749 22.75 55.5509 28.8297 55.5509C34.9095 55.5509 34.9095 55.6069 41.0453 55.6069C42.0539 55.6069 43.0905 55.2989 43.931 54.7109C44.7716 54.1509 45.5 53.2269 45.5 52.023C45.5 49.531 45.3879 48.243 45.2478 47.0111H45.1918ZM41.6056 28.1954C41.4935 29.3714 41.3535 30.6314 41.3535 33.0393C41.3535 37.8272 41.5776 37.8272 41.5776 42.4752V42.5312C41.5776 46.9831 41.8297 47.2911 41.8297 51.099C41.8297 51.351 41.8297 51.603 41.8297 51.883L41.5496 52.247L40.9332 52.499L4.42672 52.191C4.09052 52.191 3.83836 52.079 3.72629 51.995L3.55819 51.659C3.55819 49.307 3.67026 48.187 3.78233 46.9831C3.8944 45.7791 4.00647 44.5191 4.00647 42.1112V42.0552C4.00647 37.2673 3.75431 37.2393 3.75431 32.6194V32.5634C3.75431 27.8314 3.8944 27.8314 3.8944 23.0435C3.8944 22.0636 4.03448 21.1676 4.14655 20.0756C4.62284 16.0437 4.37069 15.9877 4.81897 12.0958C4.90302 11.2558 4.98707 10.8638 5.07112 10.4438C5.15517 10.0518 5.21121 9.60381 5.29526 8.87582C7.22845 8.87582 7.3125 9.01582 9.46983 9.01582H9.55388C14.2047 9.01582 14.2047 8.79183 18.7435 8.79183C21.0129 8.79183 22.1056 8.87582 23.2543 8.98782C24.403 9.07182 25.6078 9.18382 27.9332 9.18382H27.9892C31.9116 9.18382 32.444 9.18382 35.4698 9.18382C35.9461 9.18382 36.4784 9.18382 37.0948 9.18382C37.9353 9.18382 38.4677 9.07182 38.8599 8.98782C39.1961 8.93182 39.4203 8.87582 39.8685 8.84782C40.0086 10.0238 40.0647 10.1078 40.2047 11.2558C40.7371 15.7077 40.569 15.7077 41.1293 20.2436C41.3535 21.6436 41.8017 22.7075 41.8017 23.6315C41.8017 25.9555 41.6897 27.0755 41.5496 28.2514L41.6056 28.1954ZM39.7284 5.57189C34.4612 5.57189 34.2371 5.31989 28.5496 5.31989C22.694 5.31989 22.694 5.37589 16.8664 5.37589C11.1228 5.37589 11.0668 5.2359 5.35129 5.2359C4.45474 5.2359 4.73491 3.49993 5.74353 3.61193C5.77155 3.61193 5.8556 3.61193 5.8556 3.61193H6.19181C7.1444 3.61193 7.70474 3.55593 8.20905 3.49993C8.71336 3.44393 9.16164 3.38793 10.1142 3.38793H10.1703C14.569 3.38793 14.597 3.44393 18.9677 3.44393H19.0517C21.2371 3.44393 22.2737 3.55593 23.3944 3.66793C24.5151 3.77992 25.6918 3.89192 27.9332 3.89192C30.1746 3.89192 31.3513 3.77992 32.472 3.66793C33.5927 3.55593 34.6293 3.44393 36.8147 3.44393H36.8987C38.2716 3.44393 38.3276 3.44393 39.7004 3.49993C39.7004 3.49993 40.4289 3.55593 40.7091 4.31191C40.9892 5.0679 40.0927 5.59989 39.7565 5.59989L39.7284 5.57189Z" fill="black"/>
              </svg>

              <span class="cd-empty__count">0</span>
            </span>
            <h3 class="cd-empty__title">{{ section.settings.empty_heading }}</h3>
            {%- if section.settings.empty_text != blank -%}
              <p class="cd-empty__text">{{ section.settings.empty_text }}</p>
            {%- endif -%}

            {%- if section.settings.empty_collection != blank -%}
              {%- assign empty_coll = section.settings.empty_collection -%}
              <div class="cd-shop" data-cd-carousel>
                <div class="cd-shop__head">
                  <p class="cd-shop__label">{{ section.settings.empty_collection_title }}</p>
                  <div class="cd-carousel__nav">
                    <button type="button" class="cd-carousel__arrow" data-cd-prev aria-label="Previous">
                      <svg width="16" height="8" viewBox="0 0 16 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M5.96542 8C5.67819 7.33884 5.37993 6.75482 5.07061 6.24793C4.76129 5.71901 4.45197 5.26722 4.14265 4.89256H16V3.10744H4.14265C4.45197 2.71074 4.76129 2.25895 5.07061 1.75207C5.37993 1.22314 5.67819 0.639119 5.96542 0H4.40778C3.01585 1.60882 1.54659 2.7989 0 3.57025V4.42975C1.54659 5.17906 3.01585 6.36915 4.40778 8H5.96542Z" fill="black"/>
                      </svg>
                    </button>
                    <button type="button" class="cd-carousel__arrow" data-cd-next aria-label="Next">
                      <svg width="16" height="8" viewBox="0 0 16 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M10.0346 8C10.3218 7.33884 10.6201 6.75482 10.9294 6.24793C11.2387 5.71901 11.548 5.26722 11.8573 4.89256H0V3.10744H11.8573C11.548 2.71074 11.2387 2.25895 10.9294 1.75207C10.6201 1.22314 10.3218 0.639119 10.0346 0H11.5922C12.9841 1.60882 14.4534 2.7989 16 3.57025V4.42975C14.4534 5.17906 12.9841 6.36915 11.5922 8H10.0346Z" fill="black"/>
                      </svg>
                    </button>
                  </div>
                </div>
                <div class="cd-shop__track" data-cd-track>
                  {%- for product in empty_coll.products limit: 8 -%}
                    {% render 'cart-drawer-product-card', product: product, style: 'empty' %}
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}

            <a
              href="{{ section.settings.empty_button_link | default: routes.all_products_collection_url }}"
              class="cd-empty__shop-all"
            >
              {{ section.settings.empty_button_label }}
            </a>
          </div>
        {%- else -%}
          {%- comment -%} ===== REWARDS: member scheme OR spend-based tiers ===== {%- endcomment -%}
          {%- if show_member_scheme -%}
            <div class="cd-rewards cd-rewards--member">
              <p class="cd-rewards__msg">{{ member_message }}</p>
            </div>
          {%- elsif threshold_count > 0 -%}
            <div class="cd-rewards">
              <p class="cd-rewards__msg">{{ reward_message }}</p>

              <div class="cd-rewards__track">
                {%- assign prev_cents = 0 -%}
                {%- for i in (1..4) -%}
                  {%- assign ek = 'threshold_' | append: i | append: '_enable' -%}
                  {%- assign ak = 'threshold_' | append: i | append: '_amount_' | append: cur_suffix -%}
                  {%- assign lk = 'threshold_' | append: i | append: '_label' -%}
                  {%- assign enabled = section.settings[ek] -%}
                  {%- assign amt = section.settings[ak] -%}
                  {%- if amt == blank -%}
                    {%- assign ak_usd = 'threshold_' | append: i | append: '_amount_usd' -%}
                    {%- assign amt = section.settings[ak_usd] -%}
                  {%- endif -%}
                  {%- if enabled and amt > 0 -%}
                    {%- assign b_cents = amt | times: 100 -%}
                    {%- assign reached = false -%}
                    {%- if cart_cents >= b_cents -%}{%- assign reached = true -%}{%- endif -%}
                    {%- assign seg_pct = 0 -%}
                    {%- if reached -%}
                      {%- assign seg_pct = 100 -%}
                    {%- elsif cart_cents > prev_cents -%}
                      {%- assign span = b_cents | minus: prev_cents -%}
                      {%- assign done = cart_cents | minus: prev_cents -%}
                      {%- if span > 0 -%}{%- assign seg_pct = done | times: 100 | divided_by: span -%}{%- endif -%}
                    {%- endif -%}
                    <div class="cd-reward{% if reached %} is-reached{% endif %}">
                      <span class="cd-reward__bar"
                        ><span class="cd-reward__fill" style="width: {{ seg_pct }}%"></span
                      ></span>
                      <span class="cd-reward__label">
                        {%- if reached -%}
                          <span class="cd-reward__check" aria-hidden="true">&#10003;</span>
                        {% endif -%}
                        {{- section.settings[lk] -}}
                      </span>
                      <span class="cd-reward__amount">{{ amt | times: 100 | money_without_trailing_zeros }}</span>
                    </div>
                    {%- assign prev_cents = b_cents -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}

          {%- comment -%} ===== BANNER OFFER ===== {%- endcomment -%}
          {%- if section.settings.banner_enable -%}
            {%- capture banner_inner -%}
            {%- if section.settings.banner_image_desktop != blank -%}
              {%- assign bd_alt = section.settings.banner_image_desktop.alt | default: '' -%}
              {{ section.settings.banner_image_desktop | image_url: width: 1000 | image_tag: class: 'cd-banner__img cd-banner__img--desktop', widths: '500, 750, 1000', alt: bd_alt, loading: 'lazy' }}
            {%- endif -%}
            {%- if section.settings.banner_image_mobile != blank -%}
              {%- assign bm_alt = section.settings.banner_image_mobile.alt | default: '' -%}
              {{ section.settings.banner_image_mobile | image_url: width: 800 | image_tag: class: 'cd-banner__img cd-banner__img--mobile', widths: '400, 600, 800', alt: bm_alt, loading: 'lazy' }}
            {%- endif -%}
          {%- endcapture -%}
            {%- if banner_inner != blank -%}
              <div class="cd-banner">
                {%- if section.settings.banner_link != blank -%}
                  <a href="{{ section.settings.banner_link }}" class="cd-banner__link">{{ banner_inner }}</a>
                {%- else -%}
                  {{ banner_inner }}
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endif -%}

          {%- comment -%} ===== CART ITEMS ===== {%- endcomment -%}
          <cart-drawer-items class="cd-items-wrap">
            <form
              action="{{ routes.cart_url }}"
              id="CartDrawer-Form"
              class="cart__contents cart-drawer__form"
              method="post"
            >
              <div id="CartDrawer-CartItems" class="js-contents cd-items">
                {%- for item in cart.items -%}
                  {%- liquid
                    assign is_sub = false
                    if item.selling_plan_allocation != null
                      assign is_sub = true
                    endif

                    # Identify the BASE subscription group — the plain "Subscribe & Save"
                    # group, NOT the bundle/member combined groups Appstle also attaches
                    # (those carry the pre-stacked tier/member rates and are switched by
                    # the discount engine, not chosen by the shopper). Picking the first
                    # group blindly would attach the 28.75% member plan to everyone.
                    assign base_prefix = section.settings.sub_base_group_prefix | default: 'Subscribe & Save'
                    assign base_group = null
                    for group in item.product.selling_plan_groups
                      if base_group == null and group.name contains base_prefix
                        assign base_group = group
                      endif
                    endfor
                    if base_group == null and item.product.selling_plan_groups.size > 0
                      assign base_group = item.product.selling_plan_groups.first
                    endif

                    assign has_plans = false
                    assign default_plan_id = null
                    assign default_plan_percent = 0
                    if base_group != null
                      assign has_plans = true
                      assign base_default_plan = base_group.selling_plans.first
                      assign default_plan_id = base_default_plan.id
                      assign base_adj = base_default_plan.price_adjustments.first
                      if base_adj.value_type == 'percentage'
                        assign default_plan_percent = base_adj.value
                      endif
                    endif

                    assign sub_percent = default_plan_percent
                    if is_sub
                      assign cur_adj = item.selling_plan_allocation.selling_plan.price_adjustments.first
                      if cur_adj.value_type == 'percentage'
                        assign sub_percent = cur_adj.value
                      endif
                    endif

                    assign item_compare_unit = item.variant.compare_at_price
                    if item.selling_plan_allocation != null and item.selling_plan_allocation.compare_at_price > item.final_price
                      assign item_compare_unit = item.selling_plan_allocation.compare_at_price
                    endif
                    assign item_compare_line = item_compare_unit | times: item.quantity
                    assign discount_pct = 0
                    if item_compare_unit > item.final_price
                      assign saved_unit = item_compare_unit | minus: item.final_price
                      assign discount_pct = saved_unit | times: 100 | divided_by: item_compare_unit
                    endif
                  -%}

                  <div id="CartDrawer-Item-{{ item.index | plus: 1 }}" class="cd-item" role="row">
                    <div class="cd-item__media">
                      {%- if item.image -%}
                        {%- assign cd_img_alt = item.image.alt | escape -%}
                        <a href="{{ item.url }}" tabindex="-1" aria-hidden="true">
                          {{
                            item.image
                            | image_url: width: 240
                            | image_tag:
                              class: 'cd-item__img',
                              widths: '120, 180, 240',
                              alt: cd_img_alt,
                              loading: 'lazy'
                          }}
                        </a>
                      {%- endif -%}
                    </div>

                    <div class="cd-item__main">
                      <div class="cd-item__top">
                        <div class="cd-item__titles">
                          <a href="{{ item.url }}" class="cd-item__name">{{ item.product.title | escape }}</a>
                          {%- unless item.product.has_only_default_variant -%}
                            <p class="cd-item__recipe">{{ item.variant.title | escape }}</p>
                          {%- endunless -%}
                          <p class="cd-item__note">
                            {%- if is_sub -%}
                              {{ item.selling_plan_allocation.selling_plan.name }}
                            {%- else -%}
                              One-Time
                            {%- endif -%}
                          </p>
                        </div>
                        <div class="cd-item__price">
                          {%- if item_compare_unit > item.final_price -%}
                            <span class="cd-item__price-row">
                              <s class="cd-item__compare">{{ item_compare_line | money }}</s>
                              <span class="cd-item__final">{{ item.final_line_price | money }}</span>
                            </span>
                            <span class="cd-item__off">({{ discount_pct }}% Off)</span>
                          {%- else -%}
                            <span class="cd-item__final">{{ item.final_line_price | money }}</span>
                          {%- endif -%}
                        </div>
                      </div>

                      <div class="cd-item__bottom">
                        <quantity-input class="cd-qty">
                          <button
                            class="cd-qty__btn quantity__button"
                            name="minus"
                            type="button"
                            aria-label="{{ 'products.product.quantity.decrease' | t: product: item.product.title | escape }}"
                          >
                            &minus;
                          </button>
                          <input
                            class="cd-qty__input"
                            type="number"
                            name="updates[]"
                            value="{{ item.quantity }}"
                            data-quantity-variant-id="{{ item.variant.id }}"
                            data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                            min="0"
                            data-min="{{ item.variant.quantity_rule.min | default: 1 }}"
                            {% if item.variant.quantity_rule.max != null %}
                              max="{{ item.variant.quantity_rule.max }}"
                            {% endif %}
                            step="{{ item.variant.quantity_rule.increment | default: 1 }}"
                            data-index="{{ item.index | plus: 1 }}"
                            id="Drawer-quantity-{{ item.index | plus: 1 }}"
                            aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                          >
                          <button
                            class="cd-qty__btn quantity__button"
                            name="plus"
                            type="button"
                            aria-label="{{ 'products.product.quantity.increase' | t: product: item.product.title | escape }}"
                          >
                            +
                          </button>
                        </quantity-input>

                        <cart-remove-button
                          id="CartDrawer-Remove-{{ item.index | plus: 1 }}"
                          data-index="{{ item.index | plus: 1 }}"
                        >
                          <button
                            type="button"
                            class="cd-item__remove"
                            aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}"
                          >
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                              <path d="M2.5 4.5h11M6 4.5V3a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v1.5M12.5 4.5l-.6 8.5a1.5 1.5 0 0 1-1.5 1.4H5.6a1.5 1.5 0 0 1-1.5-1.4L3.5 4.5" stroke="currentColor" stroke-width="1.1"/>
                            </svg>
                          </button>
                        </cart-remove-button>

                        <div
                          id="CartDrawer-LineItemError-{{ item.index | plus: 1 }}"
                          class="cart-item__error"
                          role="alert"
                        >
                          <small class="cart-item__error-text"></small>
                        </div>
                      </div>

                      {%- if has_plans -%}
                        <div class="cd-item__sub">
                          <span class="cd-item__divider" aria-hidden="true"></span>
                          <div class="cd-item__sub-row">
                            <cart-subscription-toggle
                              class="cd-toggle{% if is_sub %} is-on{% endif %}"
                              data-line-index="{{ item.index | plus: 1 }}"
                              data-variant-id="{{ item.variant.id }}"
                              data-quantity="{{ item.quantity }}"
                              data-plan-id="{{ default_plan_id }}"
                            >
                              <button
                                type="button"
                                class="cd-toggle__switch"
                                role="switch"
                                aria-checked="{% if is_sub %}true{% else %}false{% endif %}"
                              >
                                <span class="cd-toggle__knob"></span>
                              </button>
                              <span class="cd-toggle__label">
                                {%- if is_sub -%}
                                  Auto-ship &middot; saving {{ sub_percent }}%
                                {%- else -%}
                                  Subscribe &amp; save {{ default_plan_percent }}%
                                {%- endif -%}
                              </span>
                            </cart-subscription-toggle>

                            {%- if is_sub -%}
                              <cart-subscription-selector
                                class="cd-freq"
                                data-line-index="{{ item.index | plus: 1 }}"
                                data-variant-id="{{ item.variant.id }}"
                                data-quantity="{{ item.quantity }}"
                              >
                                <select class="cd-freq__select" aria-label="Delivery frequency">
                                  {%- comment -%} Only the frequencies of the group the item is in (Appstle groups hold 4/8/12-week plans). {%- endcomment -%}
                                  {%- assign active_plan_id = item.selling_plan_allocation.selling_plan.id -%}
                                  {%- assign freq_group = null -%}
                                  {%- for group in item.product.selling_plan_groups -%}
                                    {%- for plan in group.selling_plans -%}
                                      {%- if plan.id == active_plan_id -%}{%- assign freq_group = group -%}{%- endif -%}
                                    {%- endfor -%}
                                  {%- endfor -%}
                                  {%- if freq_group == null -%}{%- assign freq_group = base_group -%}{%- endif -%}
                                  {%- for plan in freq_group.selling_plans -%}
                                    <option
                                      value="{{ plan.id }}"
                                      {% if plan.id == active_plan_id %}
                                        selected
                                      {% endif %}
                                    >
                                      {{ plan.name }}
                                    </option>
                                  {%- endfor -%}
                                </select>
                              </cart-subscription-selector>
                            {%- endif -%}
                          </div>
                        </div>
                      {%- endif -%}
                    </div>
                  </div>
                {%- endfor -%}

                <p id="CartDrawer-LiveRegionText" class="visually-hidden" role="status"></p>
                <p id="CartDrawer-LineItemStatus" class="visually-hidden" aria-hidden="true" role="status">
                  {{ 'accessibility.loading' | t }}
                </p>
              </div>
              <div id="CartDrawer-CartErrors" role="alert"></div>
            </form>
          </cart-drawer-items>

          {%- comment -%} ===== ADD MORE, SAVE MORE ===== {%- endcomment -%}
          {%- assign last_item = cart.items.last -%}
          <cart-recommendations
            class="cd-recommend"
            data-url="{{ routes.product_recommendations_url }}?section_id=cart-recommendations&intent={{ rec_intent }}&limit=6"
            data-product-id="{{ last_item.product.id }}"
          >
            <div class="cd-recommend__head">
              <p class="cd-recommend__title">
                {{ section.settings.recommend_title }}
                {%- if extra_percent > 0 -%}
                  <span class="cd-recommend__extra">(EXTRA {{ extra_percent }}%)</span>
                {%- endif -%}
              </p>
              <div class="cd-carousel__nav">
                <button type="button" class="cd-carousel__arrow" data-cd-prev aria-label="Previous">&larr;</button>
                <button type="button" class="cd-carousel__arrow" data-cd-next aria-label="Next">&rarr;</button>
              </div>
            </div>
            <div class="cd-recommend__track" data-cd-track></div>
          </cart-recommendations>

          {%- comment -%} ===== FOOTER ===== {%- endcomment -%}
          <div class="drawer__footer cd-footer">
            <div class="cart-drawer__footer">
              <div class="cd-totals">
                <div class="cd-totals__row cd-totals__row--total">
                  <span class="cd-totals__label">Subtotal</span>
                  <span class="cd-totals__value">
                    {%- if total_savings > 0 -%}
                      <s class="cd-totals__was">{{ cart.original_total_price | money }}</s>
                    {% endif -%}
                    {{ cart.total_price | money }}
                  </span>
                </div>
                {%- if total_savings > 0 -%}
                  <div class="cd-totals__row cd-totals__row--savings">
                    <span>Total Savings!</span>
                    <span>{{ total_savings | money }}</span>
                  </div>
                {%- endif -%}
              </div>

              <button type="submit" id="CartDrawer-Checkout" class="cd-checkout" name="checkout" form="CartDrawer-Form">
                {{ section.settings.checkout_label }}
              </button>

              {%- if section.settings.guarantee_text != blank -%}
                <p class="cd-guarantee">{{ section.settings.guarantee_text }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</cart-drawer>

{% schema %}
{
  "name": "Cart drawer",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "IN YOUR BAG" },
    { "type": "text", "id": "checkout_label", "label": "Checkout button label", "default": "PROCEED TO CHECKOUT" },
    { "type": "text", "id": "guarantee_text", "label": "Guarantee note", "default": "21-day money-back guarantee" },
    { "type": "header", "content": "Subscription (Appstle)" },
    {
      "type": "text",
      "id": "sub_base_group_prefix",
      "label": "Base selling-plan group name",
      "info": "The Subscribe toggle attaches the selling-plan group whose name contains this text (e.g. 'Subscribe & Save' → 5% food / 20% toppers). Bundle and member groups are skipped.",
      "default": "Subscribe & Save"
    },
    { "type": "header", "content": "Add more, save more" },
    { "type": "text", "id": "recommend_title", "label": "Title", "default": "Add more, save more" },
    {
      "type": "select",
      "id": "recommend_intent",
      "label": "Recommendation source",
      "options": [
        { "value": "related", "label": "Related products" },
        { "value": "complementary", "label": "Complementary products" }
      ],
      "default": "related",
      "info": "Set the products in the Shopify Search & Discovery app."
    },
    { "type": "header", "content": "Yum Club membership (members)" },
    {
      "type": "paragraph",
      "content": "Logged-in customers with the member tag see a flat member discount instead of the spend-based tiers."
    },
    { "type": "checkbox", "id": "member_enable", "label": "Enable member scheme", "default": true },
    { "type": "text", "id": "member_tag", "label": "Member customer tag", "default": "Yum Club Membership!" },
    { "type": "number", "id": "member_percent", "label": "Member discount %", "default": 25 },
    {
      "type": "text",
      "id": "member_message",
      "label": "Member message",
      "info": "Use {percent} for the discount value.",
      "default": "Yum Club member — {percent}% off applied"
    },
    { "type": "header", "content": "Reward thresholds (non-members)" },
    {
      "type": "paragraph",
      "content": "Enable up to 4 spend tiers. Amounts are entered per market (US/EU/UK/CH) and the cart uses the active currency, falling back to US. Use {remaining} in a message for the amount left."
    },
    {
      "type": "text",
      "id": "unlocked_message",
      "label": "All-tiers-unlocked message",
      "default": "You've unlocked every reward! 🎉"
    },
    { "type": "header", "content": "Threshold 1" },
    { "type": "checkbox", "id": "threshold_1_enable", "label": "Enable", "default": true },
    { "type": "text", "id": "threshold_1_label", "label": "Milestone label", "default": "Free Shipping" },
    {
      "type": "text",
      "id": "threshold_1_message",
      "label": "Progress message",
      "default": "You're {remaining} away from Free Shipping"
    },
    { "type": "number", "id": "threshold_1_percent", "label": "Reward discount %", "default": 0 },
    { "type": "number", "id": "threshold_1_amount_usd", "label": "Amount — US ($)", "default": 80 },
    { "type": "number", "id": "threshold_1_amount_eur", "label": "Amount — EU (€)", "default": 90 },
    { "type": "number", "id": "threshold_1_amount_gbp", "label": "Amount — UK (£)", "default": 90 },
    { "type": "number", "id": "threshold_1_amount_chf", "label": "Amount — CH (CHF)", "default": 110 },
    { "type": "header", "content": "Threshold 2" },
    { "type": "checkbox", "id": "threshold_2_enable", "label": "Enable", "default": true },
    { "type": "text", "id": "threshold_2_label", "label": "Milestone label", "default": "5% Off" },
    {
      "type": "text",
      "id": "threshold_2_message",
      "label": "Progress message",
      "default": "You're {remaining} away from 5% off"
    },
    { "type": "number", "id": "threshold_2_percent", "label": "Reward discount %", "default": 5 },
    { "type": "number", "id": "threshold_2_amount_usd", "label": "Amount — US ($)", "default": 160 },
    { "type": "number", "id": "threshold_2_amount_eur", "label": "Amount — EU (€)", "default": 180 },
    { "type": "number", "id": "threshold_2_amount_gbp", "label": "Amount — UK (£)", "default": 180 },
    { "type": "number", "id": "threshold_2_amount_chf", "label": "Amount — CH (CHF)", "default": 220 },
    { "type": "header", "content": "Threshold 3" },
    { "type": "checkbox", "id": "threshold_3_enable", "label": "Enable", "default": true },
    { "type": "text", "id": "threshold_3_label", "label": "Milestone label", "default": "10% Off" },
    {
      "type": "text",
      "id": "threshold_3_message",
      "label": "Progress message",
      "default": "You're {remaining} away from 10% off"
    },
    { "type": "number", "id": "threshold_3_percent", "label": "Reward discount %", "default": 10 },
    { "type": "number", "id": "threshold_3_amount_usd", "label": "Amount — US ($)", "default": 240 },
    { "type": "number", "id": "threshold_3_amount_eur", "label": "Amount — EU (€)", "default": 270 },
    { "type": "number", "id": "threshold_3_amount_gbp", "label": "Amount — UK (£)", "default": 270 },
    { "type": "number", "id": "threshold_3_amount_chf", "label": "Amount — CH (CHF)", "default": 330 },
    { "type": "header", "content": "Threshold 4" },
    { "type": "checkbox", "id": "threshold_4_enable", "label": "Enable", "default": true },
    { "type": "text", "id": "threshold_4_label", "label": "Milestone label", "default": "15% Off" },
    {
      "type": "text",
      "id": "threshold_4_message",
      "label": "Progress message",
      "default": "You're {remaining} away from 15% off"
    },
    { "type": "number", "id": "threshold_4_percent", "label": "Reward discount %", "default": 15 },
    { "type": "number", "id": "threshold_4_amount_usd", "label": "Amount — US ($)", "default": 320 },
    { "type": "number", "id": "threshold_4_amount_eur", "label": "Amount — EU (€)", "default": 360 },
    { "type": "number", "id": "threshold_4_amount_gbp", "label": "Amount — UK (£)", "default": 360 },
    { "type": "number", "id": "threshold_4_amount_chf", "label": "Amount — CH (CHF)", "default": 440 },
    { "type": "header", "content": "Offer banner" },
    { "type": "checkbox", "id": "banner_enable", "label": "Show banner", "default": false },
    { "type": "image_picker", "id": "banner_image_desktop", "label": "Banner image (desktop)" },
    { "type": "image_picker", "id": "banner_image_mobile", "label": "Banner image (mobile)" },
    { "type": "url", "id": "banner_link", "label": "Banner link" },
    { "type": "header", "content": "Empty state" },
    { "type": "text", "id": "empty_heading", "label": "Heading", "default": "An empty bag won't feed itself" },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Text",
      "default": "Fill it with real, gently air-dried food dogs actually finish."
    },
    { "type": "text", "id": "empty_collection_title", "label": "Collection title", "default": "Shop best sellers" },
    { "type": "collection", "id": "empty_collection", "label": "Collection" },
    { "type": "text", "id": "empty_button_label", "label": "Button label", "default": "Shop all products" },
    { "type": "url", "id": "empty_button_link", "label": "Button link" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "drawer_bg", "label": "Drawer background", "default": "#FFF9EF" },
    { "type": "color", "id": "header_bg", "label": "Header background", "default": "#661D1D" },
    { "type": "color", "id": "header_text", "label": "Header text", "default": "#FFF9EF" },
    { "type": "color", "id": "accent_color", "label": "Accent (savings)", "default": "#296900" },
    { "type": "color", "id": "cta_bg", "label": "Checkout button", "default": "#FFC069" }
  ]
}
{% endschema %}
