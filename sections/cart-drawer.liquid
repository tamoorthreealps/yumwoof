                        </div>
                        <div class="cd-item__sub-row">
                          <cart-subscription-toggle
                            class="cd-toggle{% if is_sub %} is-on{% endif %}"
                            data-line-index="{{ item.index | plus: 1 }}"
                            data-variant-id="{{ item.variant.id }}"
                            data-quantity="{{ item.quantity }}"
                            data-plan-id="{{ default_plan_id }}"
                          >
                            <button
                              type="button"
                              class="cd-toggle__switch"
                              role="switch"
                              aria-checked="{% if is_sub %}true{% else %}false{% endif %}"
                            >
                              <span class="cd-toggle__knob"></span>
                            </button>
                            <span class="cd-toggle__label">
                              {%- if is_sub -%}
                                Auto-ship &middot; saving {{ sub_percent }}%
                              {%- else -%}
                                Subscribe &amp; save {{ default_plan_percent }}%
                              {%- endif -%}
                            </span>
                          </cart-subscription-toggle>

                          {%- if is_sub -%}
                            <cart-subscription-selector
                              class="cd-freq"
                              data-line-index="{{ item.index | plus: 1 }}"
                              data-variant-id="{{ item.variant.id }}"
                              data-quantity="{{ item.quantity }}"
                            >
                              <select class="cd-freq__select" aria-label="Delivery frequency">
                                {%- comment -%} Only the frequencies of the group the item is in (Appstle groups hold 4/8/12-week plans). {%- endcomment -%}
                                {%- assign active_plan_id = item.selling_plan_allocation.selling_plan.id -%}
                                {%- assign freq_group = null -%}
                                {%- for group in item.product.selling_plan_groups -%}
                                  {%- for plan in group.selling_plans -%}
                                    {%- if plan.id == active_plan_id -%}{%- assign freq_group = group -%}{%- endif -%}
                                  {%- endfor -%}
                                {%- endfor -%}
                                {%- if freq_group == null -%}{%- assign freq_group = base_group -%}{%- endif -%}
                                {%- for plan in freq_group.selling_plans -%}
                                  <option
                                    value="{{ plan.id }}"
                                    {% if plan.id == active_plan_id %}
                                      selected
                                    {% endif %}
                                  >
                                    {{ plan.name }}
                                  </option>
                                {%- endfor -%}
                              </select>
                            </cart-subscription-selector>
                          {%- endif -%}
                        </div>
                      </div>
                    {%- endif -%}
                  </div>
                {%- endfor -%}

                <p id="CartDrawer-LiveRegionText" class="visually-hidden" role="status"></p>
                <p id="CartDrawer-LineItemStatus" class="visually-hidden" aria-hidden="true" role="status">
                  {{ 'accessibility.loading' | t }}
                </p>
              </div>
              <div id="CartDrawer-CartErrors" role="alert"></div>
            </form>
          </cart-drawer-items>

          {%- comment -%} ===== ADD MORE, SAVE MORE ===== {%- endcomment -%}
          {%- assign last_item = cart.items.last -%}
          <cart-recommendations
            class="cd-recommend"
            data-url="{{ routes.product_recommendations_url }}?section_id=cart-recommendations&intent={{ rec_intent }}&limit=6"
            data-product-id="{{ last_item.product.id }}"
          >
            <div class="cd-recommend__head">
              <p class="cd-recommend__title">
                {{ section.settings.recommend_title }}
                {%- if extra_percent > 0 -%}
                  <span class="cd-recommend__extra">(EXTRA {{ extra_percent }}%)</span>
                {%- endif -%}
              </p>
              <div class="cd-carousel__nav">
                <button type="button" class="cd-carousel__arrow" data-cd-prev aria-label="Previous">
                  <svg width="16" height="8" viewBox="0 0 16 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M5.96542 8C5.67819 7.33884 5.37993 6.75482 5.07061 6.24793C4.76129 5.71901 4.45197 5.26722 4.14265 4.89256H16V3.10744H4.14265C4.45197 2.71074 4.76129 2.25895 5.07061 1.75207C5.37993 1.22314 5.67819 0.639119 5.96542 0H4.40778C3.01585 1.60882 1.54659 2.7989 0 3.57025V4.42975C1.54659 5.17906 3.01585 6.36915 4.40778 8H5.96542Z" fill="black"/>
                  </svg>
                </button>
                <button type="button" class="cd-carousel__arrow" data-cd-next aria-label="Next">
                  <svg width="16" height="8" viewBox="0 0 16 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M10.0346 8C10.3218 7.33884 10.6201 6.75482 10.9294 6.24793C11.2387 5.71901 11.548 5.26722 11.8573 4.89256H0V3.10744H11.8573C11.548 2.71074 11.2387 2.25895 10.9294 1.75207C10.6201 1.22314 10.3218 0.639119 10.0346 0H11.5922C12.9841 1.60882 14.4534 2.7989 16 3.57025V4.42975C14.4534 5.17906 12.9841 6.36915 11.5922 8H10.0346Z" fill="black"/>
                  </svg>
                </button>
              </div>
            </div>
            <div class="splide cd-recommend__slider" data-cd-slider>
              <div class="splide__track" data-cd-track>
              </div>
            </div>
          </cart-recommendations>

          {%- comment -%} ===== FOOTER ===== {%- endcomment -%}
          <div class="drawer__footer cd-footer">
            <div class="cart-drawer__footer">
              <div class="cd-totals">
                <div class="cd-totals__row cd-totals__row--total">
                  <span class="cd-totals__label">Subtotal</span>
                  <span class="cd-totals__value">
                    {%- if total_savings > 0 -%}
                      <s class="cd-totals__was">{{ cart.original_total_price | money }}</s>
                    {% endif -%}
                    {{ cart.total_price | money }}
                  </span>
                </div>
                {%- if total_savings > 0 -%}
                  <div class="cd-totals__row cd-totals__row--savings">
                    <span>Total Savings!</span>
                    <span>{{ total_savings | money }}</span>
                  </div>
                {%- endif -%}
              </div>

              <button type="submit" id="CartDrawer-Checkout" class="cd-checkout" name="checkout" form="CartDrawer-Form">
                {{ section.settings.checkout_label }}
              </button>

              {%- if section.settings.guarantee_text != blank -%}
                <p class="cd-guarantee">{{ section.settings.guarantee_text }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</cart-drawer>

